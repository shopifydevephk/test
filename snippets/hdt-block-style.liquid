{%- case type -%}
  {%- when 'text' -%}
    --color-text: {{- block.settings.color_text -}};--color-text-rgb: {{- block.settings.color_text.rgb -}};--font-size: {{- block.settings.font_size -}}px;--font-size-mobile: {{- block.settings.font_size_mobile -}}px;--line-height: {% if block.settings.line_height == 0 %}1{% else %}{{ block.settings.line_height }}px{% endif %};--line-height-mobile: {% if block.settings.line_height_mobile == 0 %}1{% else %}{{ block.settings.line_height_mobile }}px{% endif %};--font-weight: {{- block.settings.font_weight -}};--letter-spacing: {{- block.settings.letter_spacing -}}px;--letter-spacing-mobile: {{- block.settings.letter_spacing_mobile -}}px;--margin-bottom: {{- block.settings.margin_bottom | default: 0 -}}px;--margin-bottom-mobile: {{- block.settings.margin_bottom_mobile | default: 0 -}}px;
  {%- when 'button' -%}
    --button-fs: {{ block.settings.font_size }}px;--button-fw: {{ block.settings.font_weight }};--button-ls: {{ block.settings.letter_spacing }}px;--button-mh: {{ block.settings.min_height }}px;--button-pd-lr: {{ block.settings.padding_left_right }}px;--button-mgb: {{ block.settings.margin_bottom | default: 0 }}px;--button-fs-mb: {{ block.settings.font_size_mobile }}px;--button-ls-mb: {{ block.settings.letter_spacing_mobile }}px;--button-mh-mb: {{ block.settings.min_height_mobile }}px;--button-pd-lr-mb: {{ block.settings.padding_left_right_mobile }}px;--button-mgb-mb: {{ block.settings.margin_bottom_mobile | default: 0 }}px;--second-cl: {{ block.settings.secondary_color }};--second-cl-hover: {{ block.settings.secondary_color_hover }};--pri-cl: {{ block.settings.primary_color }};--pri-cl-hover: {{ block.settings.primary_color_hover }};--button-bdr: {{ block.settings.border_radius }}px;--button-icon-w: {{ block.settings.icon_width }}px;--button-icon-w-mb: {{ block.settings.icon_width_mobile }}px;
{%- endcase -%}