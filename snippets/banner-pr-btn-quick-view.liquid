{%- comment -%}
  Renders btn quick view

  Accepts:
  - product: {Object} Product Liquid object (required)
  - section_id: {String} The ID of the section that contains this card. (required)
  - class: {String} a list class. (optional)
  - disable_sr_only: {Boolean} remove class sr_only (optional)
  - placement: {String} position tooltip (optional)

  Usage:
  {%- render 'btn-quick-view', product: card_product, section_id: section_id -%}
{%- endcomment -%}
<wrapp-hdt-open-modal-btn placement="{{ placement | default: 'none' }}" {{ tooltip_auto }} class="{{ class }}">
  <button type="button" handle="{{ product.handle }}" aria-controls="hdt-quick-view-modal" aria-expanded="false" class="hdt-card-product__btn-quick-view {{ btn_class }}" {{ attr }} aria-label="{{ 'products.product.quick_view' | t }}">
    <div class="hdt-banner-pr__media">
      <div class="hdt-ratio" style="--aspect-ratioapt: {{ product.featured_image.aspect_ratio }};">
        {%- liquid
          echo product.featured_image | image_url: width: product.featured_image.width | image_tag: width: product.featured_image.width, class: 'w-full h-full object-cover', loading: 'lazy'
        -%}
      </div>
    </div>
    <span {% unless disable_sr_only %}class="sr-only"{% endunless %}>{{ 'products.product.quick_view' | t }}</span>
  </button>
</wrapp-hdt-open-modal-btn>