<div class="hdt-quote-wrap">
  <div class="hdt-quote-infors">
    {%- if block.settings.image_avata -%}
      {%- assign image = block.settings.image_avata -%} 
       {{ image | image_url: width: image.width | image_tag: loading: 'lazy', width: image.width, height: image.height, widths: '200,400,600,800,1000', class: 'hdt-quote-avatar' }}
      {%- endif -%}
    <div class="hdt-quote-au-rev">
      <div class="hdt-quote-author">{{ block.settings.title }}</div>
      {%- if block.settings.pos != blank -%}<div class="hdt-quote-position">{{ block.settings.pos }}</div>{%- endif -%} 
       {%- render 'rating_star', rating: block.settings.rating -%}
    </div>
  </div>
  <div class="hdt-quote-texts hdt-rte">{{ block.settings.content }}</div>
</div>