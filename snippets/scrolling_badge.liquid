{%- liquid
  unless settings.enable_scroll_badge
    continue
  endunless
  assign icon = product.metafields.theme.scrolling_badge.value.icon | default: settings.scroll_badge_icon
  assign text = product.metafields.theme.scrolling_badge.value.text | default: settings.scroll_badge_text
  assign show_sale_percentage = product.metafields.theme.scrolling_badge.value.show_sale_percentage | default: settings.scroll_badge_sale_percentage
  assign show_sale_text = product.metafields.theme.scrolling_badge.value.show_sale_text | default: settings.scroll_badge_sale_text
  assign icon_center = product.metafields.theme.scrolling_badge.value.icon_center | default: settings.scroll_badge_icon_center
  assign is_show = true
  if icon == blank and text == blank and show_sale_percentage == false and show_sale_text == false
    assign is_show = false
  endif
    
  assign on_sale = false
  if product.compare_at_price > product.price
    assign on_sale = true
  endif

  if icon == blank and text == blank 
    if on_sale == false
      assign is_show = false 
    endif
  endif

  if is_show == false
    continue
  endif

  if product.available or product != blank
    if product.variants.size > variants_available.size
      continue
    endif
  else 
    continue
  endif


  assign show_block = settings.scrolling_badge_enable
  if show_block == false
    continue
  endif

  assign target = product

  assign show_badge_sale = false
  if show_sale_percentage or show_sale_text 
   assign show_badge_sale = true
  endif

  unless sale_text_t
    assign sale_text_t = 'products.product.on_sale' | t
  endunless
  unless sale_percent_t
    assign sale_percent_t = 'products.product.save_percent_single' | t: percent: 'save_1904'
    assign sale_percent_t = sale_percent_t | replace_first: 'save_1904%', '<span percent>save_1904%</span>&nbsp;'
  endunless
  assign icon_markup = ''
  if icon != blank
    capture icon_markup
      echo '<div class="hdt-scrolling-icon">'
      echo icon
      echo '</div>'
    endcapture
  endif
  assign text_markup = ''
  if text != blank
    capture text_markup
      echo '<p class="hdt-scrolling-text hdt-uppercase">'
      echo text
      echo '</p>'
    endcapture
  endif
  assign badge_markup = ''
  if on_sale and show_badge_sale
    capture badge_markup
      echo '<hdt-badge'
      if update_hidden_attr != blank
        echo ' '
        echo update_hidden_attr
      endif
      echo ' is="on_sale" class="hdt-badge hdt-badge__on-sale">'
      if show_sale_percentage
        assign save_percent = target.compare_at_price | minus: target.price | times: 100.0 | divided_by: target.compare_at_price | round | at_least: 1
        echo sale_percent_t | replace_first: 'save_1904', save_percent
      else
        echo sale_text_t
      endif
      echo '</hdt-badge>'
    endcapture
  endif
  assign content_order = ''
  if text_markup != ''
    assign content_order = 'text'
  endif
  if badge_markup != ''
    if content_order == ''
      assign content_order = 'sale'
    else
      assign content_order = content_order | append: ',sale'
    endif
  endif
  assign has_multiple_blocks = false
  if content_order contains ','
    assign has_multiple_blocks = true
  endif
  assign phrase_markup = ''
  if text_markup != '' or badge_markup != ''
    capture phrase_markup
      echo text_markup
      echo badge_markup
    endcapture
  endif
%}
<hdt-marquee speed-factor="0.1" direction="rtl" pausable class="hdt-marquee hdt-block hdt-left-0 hdt-right-0 hdt-bottom-0 hdt-oh hdt-current-scrollbar hdt-scrolling-badge">
  <div class="hdt-marquee-inner">
    <div class="hdt-marquee-item">
        <div class="hdt-marquee__item hdt-inline-block">
          <div class="hdt-scrolling-inner hdt-scrolling-wrap hdt-inline-flex hdt-align-center">
            {%- if icon_center and icon_markup != '' -%}
              {%- for _i in (1..10) -%}
                {{ phrase_markup }}
                {{ icon_markup }}
              {%- endfor -%}
              {{ phrase_markup }}
            {%- else -%}
              {{ icon_markup }}
              {{ text_markup }}
              {{ badge_markup }}
            {%- endif -%}
          </div>
        </div>
    </div>
  </div>
</hdt-marquee>
