															for product in products_suggests limit: 5
																render 'card-product9', card_product: product, section_id: section.id, class: "hdt-pr-style9", sizes: sizes, image_ratio: section.settings.image_ratio, color_list: color_list, size_list: size_list, product_url: product_url, btn_wishlist_code: btn_wishlist_code, show_vendor: settings.predictive_search_show_vendor, show_price: settings.predictive_search_show_price, tooltip_inner: true
															endfor
