<!-- sections/hero-image.liquid -->
{{ 'hdt-hero.css' | asset_url | stylesheet_tag }}
{%- liquid
  #Section layout
  assign sizes  = '(min-width: 1150px) ' | append: settings.page_width | append: 'px,(min-width: 750px) calc(100vw - 60px), calc(100vw - 30px)'

  case section.settings.section_layout 
    when 'container'
      assign parent = 'hdt-container'
      assign child  = 'hdt-section-spacing hdt-s-gradient hdt-relative' | append: ' hdt-section-spacing-' | append: section.id
      assign rounded = 'hdt-radius'
    when 'wrapper_container'
      assign parent = 'hdt-section-spacing hdt-s-gradient hdt-relative' | append: ' hdt-section-spacing-' | append: section.id
      assign child  = 'hdt-container'
      assign rounded = 'hdt-radius'
    when 'full_width'
      assign parent = 'hdt-container-full hdt-section-spacing hdt-s-gradient hdt-relative' | append: ' hdt-section-spacing-' | append: section.id
      assign child  = ''
      assign rounded = ''
      assign sizes  = '100vw'
  endcase
-%}
{%- liquid
  assign object_pos = section.settings.image_mb.presentation.focal_point
  assign class_object_mb = ''
  if section.index == 1
    assign loading = 'eager'
    assign fetchpriority = 'high'
  else
    assign loading = 'lazy'
    assign fetchpriority = 'auto'
  endif
  assign image_height = section.settings.image_height
  assign image_height_mb = section.settings.image_height_mb

  assign image_mb = section.settings.image_mb | default: section.settings.image
-%}
{%- style -%}
  {% render 'spacing-vars', box: section %}
#Image-{{section.id}}{ {% if image_height=='adapt_image' or image_height=='fixed' %}--aspect-ratioapt-md:{% if image_height=='fixed' %}{{section.settings.fixed_height}}px{% else %}{{section.settings.image.aspect_ratio | default:2}}{% endif %};{% endif %}{% if image_height_mb=='adapt_image' or image_height_mb=='fixed' %}--aspect-ratioapt:{% if image_height_mb=='fixed' %}{{section.settings.fixed_height_mb}}px{% else %}{{image_mb.aspect_ratio | default:2}}{% endif %};{% endif %}}
#shopify-section-{{ section.id }} {
      --content-pd-tb-dk: {{ section.settings.padding_vertical }}px;
      --content-pd-lr-dk: {{ section.settings.padding_horizontal }}px;
      --content-min-width: {{ section.settings.min_width_content }}px;
    }
{%- endstyle -%}
<div id="Image-{{ section.id }}" class="{{ parent }} hdt-hero-image hdt-section-spacing hdt-section-spacing-{{ section.id }} md:hdt-height--{{ image_height }} hdt-height--{{ image_height_mb }} {% if section.settings.hdt_background_parallax %} hdt-animate--parallax-bg {% endif %}" {%- if section.settings.colors_by_section %} color-scheme="{{ section.settings.color_scheme }}" style="--background-opacity: {{ section.settings.background_opacity }};"{%- endif %}>
  <div class="{{ child }}" style="--overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.00 }};">
    <div class="hdt-relative">
      <hdt-effect-img
        data-video-inline
        eff="{% if section.settings.image_behavior == 'ambient' %}ambient{% endif %}"
        class="hdt-hero-image__inner hdt-animate--{{ section.settings.image_behavior }} hdt-hero-image__overlay--{{ section.settings.overlay_content }} hdt-media-overlap-content{% if section.settings.image_behavior == 'parallax' %} hdt-animate--parallax{% endif %} {{ rounded }}"
        {% if object_pos != blank %}
          {%- assign class_object_mb = 'hdt-object-pos-mb' %} style="--object-pos-mb: {{ object_pos }}"
        {% endif %}
      >
        {%- liquid
          if section.settings.image != blank
            echo '<picture class="hdt-media-wrapper">'
            if section.settings.image_mb != blank and section.settings.image_mb != section.settings.image
              assign srcset = section.settings.image_mb | image_url: width: section.settings.image_mb.width | image_tag: widths: '200,400,600,800,1000', alt: null | split: 'srcset="' | last
              unless srcset contains 'src='
                echo '<source media="(max-width: 767px)" srcset="' | append: srcset | replace_first: 'style=', 'data-none='
              endunless
            endif
            echo section.settings.image | image_url: width: section.settings.image.width | image_tag: loading: loading, fetchpriority: fetchpriority, sizes: '100vw', class: class_object_mb, widths: '400,600,800,1000,1200,1400,1600,1800,2000,2200,2400,2600,2800,3000,3200'
            echo '</picture>'
          else
            echo '<div class="hdt-media-wrapper">'
            echo 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg hdt-placeholder'
            echo '</div>'
          endif
        -%}
        {%- if section.settings.link_img != blank -%}
          <a href="{{ section.settings.link_img }}" target="{% if section.settings.target %}_blank{% else %}_self{% endif %}"></a>
        {%- endif -%}
        <div class="hdt-grid hdt-h-full{% unless request.design_mode %} hdt-pe-none{% endunless %} hdt-content-type-{{ section.settings.content_position_type }}" style="--content-position-x: {{ section.settings.position_x }}%;--content-position-y: {{ section.settings.position_y }}%;--content-position-mb-x: {{ section.settings.position_x_mb }}%;--content-position-mb-y: {{ section.settings.position_y_mb }}%;--border-color: {{ section.settings.border_color }};--background-border: {{ section.settings.background_border.rgb }};--background-content-color: {{ section.settings.background_content_color.rgb }};">
          <div class="hdt-content hdt-radius hdt-place-self-{{ section.settings.content_position_mb }} md:hdt-place-self-{{ section.settings.content_position }} {% if section.settings.background_content %} hdt-background-content{% endif %}{% if section.settings.use_border_content %} hdt-content-use-border{% endif %}{% if section.settings.box_square %} hdt-content-boxsquare{% endif %}{% if section.settings.content_rounded %} hdt-radius-full{% endif %}"{% if section.settings.background_content %} style="--content-bg-opacity: {{ section.settings.bg_opacity | divided_by: 100.00 }};--content-border-opacity: {{ section.settings.border_opacity | divided_by: 100.00 }};--content-border-style: {{ section.settings.border_style }};--border-pd-dk: {{ section.settings.border_pd_dk }}px;--border-pd-mb: {{ section.settings.border_pd }}px;" reval{% endif %}>
            <div class="hdt-content-inner hdt-text-{{ section.settings.alignment_mb }} md:hdt-text-{{ section.settings.alignment }}">
              {% content_for 'blocks' %}
            </div>
          </div>
        </div>
      </hdt-effect-img>
      <div class="hdt-product-list-wrap">
        <div class="hdt-product-list">
          {% for product in section.settings.product_list %}
            {% assign image = product.featured_image %}
            <wrapp-hdt-open-modal-btn placement="top" class="hdt-banner-product__item" style="background-image: url({{ image | image_url: width: 1 }});">
              <button type="button" handle="{{ product.handle }}" aria-controls="hdt-quick-view-modal" aria-expanded="false" aria-label="{{ 'products.product.quick_view' | t }}">
                {%- liquid
                  
                  echo image | image_url: width: image.width, height: image.height | image_tag: width: image.width, widths: '100,200,400,600,700,800,900,1000,1200,1400,1600', class: 'w-full h-full object-cover', loading: 'lazy'
                -%}
                <span class="sr-only">{{ 'products.product.quick_view' | t }}</span>
              </button>
            </wrapp-hdt-open-modal-btn>
          {% else %}
            {%- for i in (1..5) -%}
              {%- capture current -%}{%- cycle 1, 2, 3, 4, 5, 6 -%}{%- endcapture -%}
              <div class="hdt-banner-product__item">
                  <button>
                      {{ 'product-' | append: current | placeholder_svg_tag: 'hdt--placeholder-svg' }}
                  </button>
              </div>
          {%- endfor -%}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>
