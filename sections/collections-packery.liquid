<!-- collections-list.liquid -->
{{ 'hdt-collection-items.css' | asset_url | stylesheet_tag }}
{%- liquid
  #Section layout
  assign sizes  = '(min-width: 1150px) ' | append: settings.page_width | append: 'px,(min-width: 750px) calc(100vw - 60px), calc(100vw - 30px)'

  case section.settings.section_layout 
    when 'container'
      assign parent = 'hdt-container'
      assign child  = 'hdt-section-spacing hdt-s-gradient hdt-relative' | append: ' hdt-section-spacing-' | append: section.id
    when 'wrapper_container'
      assign parent = 'hdt-section-spacing hdt-s-gradient hdt-relative' | append: ' hdt-section-spacing-' | append: section.id
      assign child  = 'hdt-container'
    when 'full_width'
      assign parent = 'hdt-container-full hdt-section-spacing hdt-s-gradient hdt-relative' | append: ' hdt-section-spacing-' | append: section.id
      assign child  = ''
      assign sizes  = '100vw'
  endcase
-%}
{%- liquid
  assign current_width = settings.page_width | append: 'px'
  assign current_width_tb = '100vw'
  assign current_width_mb = '100vw'
  if section.settings.space_items == "x"
    assign space_item = settings.spacing_grid_horizontal
  else
    assign space_item = section.settings.space_items
  endif
-%}
{%- style -%}
  {% render 'spacing-vars', box: section %}
{%- endstyle -%}
{%- style -%}
  #{{ section.id }} hdt-slider {
    --slide-spacing: {{ space_item }}px;
  } 
  #{{section.id}} .hdt-collections-list{
    --content-space:{{section.settings.content_space}}px;
  }
  {% if section.settings.image_padding > 30 %}
    #{{section.id}} .hdt-collections-list {
      --image-pd:15px
    }
    @media(min-width:768px){
      #{{section.id}} .hdt-collections-list{ 
        --image-pd:30px
      }
    }
    @media(min-width:1150px){
      #{{section.id}} .hdt-collections-list{
        --image-pd:{{section.settings.image_padding}}px;
      }
    }
    {% elsif section.settings.image_padding > 15 %}
      #{{section.id}} .hdt-collections-list{
        --image-pd:15px;
      }
      #{{section.id}} .hdt-collections-list .hdt-slider-parent.hdt-slider__dots_on_content {
        --image-pd:{{section.settings.image_padding}}px;
      }
    @media(min-width:768px){
      #{{section.id}} .hdt-collections-list{
        --image-pd:{{section.settings.image_padding}}px;
      }
    }
  {% else %}
    #{{section.id}} .hdt-collections-list {
      --image-pd:{{section.settings.image_padding}}px;
    }
  {% endif %}
{%- endstyle -%}
<div id="{{ section.id }}" class="{{ parent }} {% if section.settings.hdt_background_parallax %} hdt-animate--parallax-bg {% endif %}" {%- if section.settings.colors_by_section %} color-scheme="{{ section.settings.color_scheme }}" style="--background-opacity: {{ section.settings.background_opacity }};"{%- endif %}>
  <div class="{{ child }}">     
    {%- if section.settings.section_background != blank -%}
      {% liquid
        assign image = section.settings.section_background
      %}
      {{ image | image_url: width: image.width | image_tag: width: image.width, height: image.height, sizes: sizes, widths: '200,300,400,500,600,700,800,900,1000,1100,1200,1300,1400,1500,1600,1700,1800,1900,2000', loading: 'lazy', class: 'hdt-section-background hdt-absolute hdt-top-0 hdt-left-0 hdt-w-full hdt-h-full hdt-pe-none hdt-object-cover hdt-object-center' }}
    {%- endif -%}
    {%- content_for 'block', type: 'section-heading', id: "section-heading-collections-list" -%}
    <packery-layout class="hdt-block hdt-oh" layout="[data-layout]" selector="[item-selector]">
      <div class="hdt-collections-list hdt-has-collection{{ section.settings.collection_des }} hdt-colelction-border-{{ section.settings.enable_border }} hdt-image-rounded-{{ section.settings.image_rounded }} hdt-ratio--{{ section.settings.image_ratio }} {% unless section.settings.image_size %} hdt-ratio--contain{% endunless %} hdt-relative  hdt-gutter-{{ section.settings.gap_item_mb }} md:hdt-gutter-{{ section.settings.gap_item_tb }} lg:hdt-gutter-{{ section.settings.gap_item_dk }}" data-layout>
        {% content_for 'blocks' %}
      </div>
    </packery-layout>
  </div>
</div>
<script src="{{ 'packery.js' | asset_url }}" defer></script>

