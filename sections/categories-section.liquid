<!-- sections/categories-section.liquid -->
{{ 'categories-section.css' | asset_url | stylesheet_tag }}
{%- liquid
  #Section layout
  assign sizes  = '(min-width: 1150px) ' | append: settings.page_width | append: 'px,(min-width: 750px) calc(100vw - 60px), calc(100vw - 30px)'

  case section.settings.section_layout 
    when 'container'
      assign parent = 'hdt-container'
      assign child  = 'hdt-section-spacing hdt-s-gradient hdt-relative' | append: ' hdt-section-spacing-' | append: section.id
    when 'wrapper_container'
      assign parent = 'hdt-section-spacing hdt-s-gradient hdt-relative' | append: ' hdt-section-spacing-' | append: section.id
      assign child  = 'hdt-container'
    when 'full_width'
      assign parent = 'hdt-container-full hdt-section-spacing hdt-s-gradient hdt-relative' | append: ' hdt-section-spacing-' | append: section.id
      assign child  = ''
      assign sizes  = '100vw'
  endcase
-%}
{%- style -%}
  {% render 'spacing-vars', box: section %}
{%- endstyle -%}
<div id="section-{{ section.id }}" class="{{ parent }} {% if section.settings.hdt_background_parallax %} hdt-animate--parallax-bg {% endif %}" {%- if section.settings.colors_by_section %} color-scheme="{{ section.settings.color_scheme }}" style="--background-opacity: {{ section.settings.background_opacity }};"{%- endif %}>
  <div class="{{ child }}">
    {%- if section.settings.section_background != blank -%}
      {% liquid
        assign image = section.settings.section_background
      %}
      {{ image | image_url: width: image.width | image_tag: width: image.width, height: image.height, sizes: sizes, widths: '200,300,400,500,600,700,800,900,1000,1100,1200,1300,1400,1500,1600,1700,1800,1900,2000', loading: 'lazy', class: 'hdt-section-background hdt-absolute hdt-top-0 hdt-left-0 hdt-w-full hdt-h-full hdt-pe-none hdt-object-cover hdt-object-center' }}
    {%- endif -%}
    <div class="hdt-container-heading">
      {%- content_for "block", type: "section-heading", id: "categories" -%}
    </div>
    <div class="hdt-wrapper hdt-oh">
      <div class="hdt-wrap hdt-flex lg:hdt-justify-center hdt-text-center hdt-ratio--square" style="--item-size: {{ section.settings.item_size }}px; --item-size-tablet: {{ section.settings.item_size_tablet }}px; --item-size-mobile: {{ section.settings.item_size_mobile }}px;">
        {%- if section.settings.collections != blank -%}
          {%- assign categories_ids = section.settings.collections | map: 'id' | join: ',.hdt-category-' | prepend: '.hdt-category-' | split: ',' -%}
          <style>{%- for class in categories_ids -%}{{ class }} {order: {{ forloop.index }};}{% endfor -%}</style>
        {%- endif -%}
        <hdt-slider id="Slider-{{ section.id }}" class="hdt-slider hdt-categories_container hdt-block hdt-oh hdt-spacing-{{ section.settings.space_items }}" config='{ "id": "Slider-{{ section.id }}", "active": true, "breakpoints": { "(max-width: 1149px)": { "active": false } } }' style="--slides-dk: max({{ 100 | divided_by: section.settings.limit }}%, var(--item-size)); --slides-tb: max({{ 100 | divided_by: section.settings.limit_tablet }}%, var(--item-size-tablet)); --slides-mb: max({{ 100 | divided_by: section.settings.limit_mobile }}%, var(--item-size-mobile)); --slide-spacing: var(--spacing-x);">
          <div class="hdt-slider__viewport">
            <div class="hdt-slider__container md@hdt-scroll-snap md@hdt-snap-flex">
              {%- capture categories_blocks -%}
                {%- content_for 'blocks' -%}
              {%- endcapture -%}
              {%- for collection in section.settings.collections -%}
                {%- if categories_blocks contains collection.id -%}{% continue %}{%- endif -%}
                <div class="hdt-slider__slide hdt-category-{{ collection.id }}">
                  <div class="hdt-categories_item hdt-flex hdt-flex-col hdt-align-center" hdt-reveal="slide-in" timeline>
                    <div class="hdt-relative hdt-oh">
                      <a href="{{ collection.url }}" class=" hdt-block hdt-categories_image hdt-ratio hdt-oh hdt-radius-full">
                        {%- if collection.featured_image != blank -%}
                          {{ collection.featured_image | image_url: width: collection.featured_image.width | image_tag: loading: 'lazy', width: collection.featured_image.width, height: collection.featured_image.height, class: '', sizes: '(min-width: 768px) 160px, 135px', widths: '100,135,160,200,270,320' }}
                        {%- else -%}
                          {%- capture name_img -%}
                            {%- cycle 'collection-apparel-1', 'collection-apparel-2', 'collection-apparel-3', 'collection-apparel-4' -%}
                          {%- endcapture -%}
                          {{ name_img | placeholder_svg_tag: 'placeholder-svg hdt-oh hdt-radius-full' }}
                        {%- endif -%}
                      </a>
                      {%- if collection.metafields.theme.label != blank -%}
                        <span class="hdt-collection_label hdt-absolute hdt-top-0 hdt-left-0 hdt-text-xs hdt-radius-full hdt-font-medium hdt-align-center hdt-justify-center" >{{ collection.metafields.theme.label }}</span>
                      {%- endif -%}
                    </div>
                    <a href="{{ collection.url }}" class="hdt-btn hdt-btn-link {{ section.settings.font_size }}">{{ collection.title }}</a>
                  </div>
                </div>
              {%- endfor -%}              
              {%- if section.blocks.size == 0 and section.settings.collections == blank -%}
                {%- for i in (1..8) -%}
                  <div class="hdt-slider__slide">
                    <div class="hdt-categories_item hdt-flex hdt-flex-col hdt-align-center" hdt-reveal="slide-in" timeline>
                      <div class="hdt-relative hdt-oh">
                        <a href="#" class="hdt-block hdt-categories_image hdt-ratio hdt-oh hdt-radius-full">
                          {%- capture name_img -%}
                            {%- cycle 'collection-apparel-1', 'collection-apparel-2', 'collection-apparel-3', 'collection-apparel-4' -%}
                          {%- endcapture -%}
                          {{ name_img | placeholder_svg_tag: 'placeholder-svg hdt-oh hdt-radius-full' }}
                        </a>
                        {%- if collection.metafields.theme.label != blank -%}
                          <span class="hdt-collection_label hdt-absolute hdt-top-0 hdt-left-0 hdt-text-xs hdt-radius-full hdt-font-medium hdt-align-center hdt-justify-center" >{{ collection.metafields.theme.label }}</span>
                        {%- endif -%}
                      </div>
                      <a href="#" class="hdt-btn hdt-btn-link {{ section.settings.font_size }}">Collection title</a>
                    </div>
                  </div>
                {%- endfor -%}
              {%- endif -%}
              {{ categories_blocks }}
            </div>
          </div>
        </hdt-slider>
      </div>
    </div>
  </div>
</div>
{% schema %}
{
  "name": "Categories",
  "class": "hdt-categories-section hdt-section",
  "tag": "section",
  "disabled_on": {
    "groups": [
      "*"
    ]
  },
  "settings": [
    {
      "type": "collection_list",
      "id": "collections",
      "label": "Collections"
    },
    {
      "type": "header",
      "content": "General options"
    },
    {
      "type": "range",
      "id": "item_size",
      "label": "Item Size Desktop",
      "min": 100,
      "max": 200,
      "step": 1,
      "default": 100,
      "unit": "px"
    },
    {
      "type": "paragraph",
      "content": "The maximum size depends on the number of items per row. For example, if you place 8 items per row, the size of each item cannot be larger than 130px"
    },
    {
      "type": "range",
      "id": "item_size_tablet",
      "label": "Item Size Tablet",
      "min": 55,
      "max": 100,
      "step": 1,
      "default": 55,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "item_size_mobile",
      "label": "Item Size Mobile",
      "min": 55,
      "max": 100,
      "step": 1,
      "default": 55,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "font_size",
      "label": "Title font size",
      "options": [
        {
          "value": "hdt-text-xs",
          "label": "t:settings_schema.typography.settings.font_size.xs"
        },
        {
          "value": "hdt-text-sm",
          "label": "t:settings_schema.typography.settings.font_size.sm"
        },
        {
          "value": "hdt-text-base",
          "label": "t:settings_schema.typography.settings.font_size.base"
        },
        {
          "value": "hdt-text-lg",
          "label": "t:settings_schema.typography.settings.font_size.lg"
        },
        {
          "value": "hdt-text-xl",
          "label": "t:settings_schema.typography.settings.font_size.xl"
        },
        {
          "value": "hdt-text-2xl",
          "label": "t:settings_schema.typography.settings.font_size.2xl"
        },
        {
          "value": "hdt-text-4xl",
          "label": "t:settings_schema.typography.settings.font_size.4xl"
        }
      ],
      "default": "hdt-text-base"
    },
    {
      "type": "range",
      "id": "limit",
      "min": 1,
      "max": 10,
      "step": 1,
      "label": "Number Of Item Displayed (Desktop)",
      "default": 8
    },
    {
      "type": "range",
      "id": "limit_tablet",
      "min": 1,
      "max": 6,
      "step": 1,
      "label": "Number Of Item Displayed (Tablet)",
      "default": 4
    },
    {
      "type": "range",
      "id": "limit_mobile",
      "min": 1,
      "max": 5,
      "step": 1,
      "label": "Number Of Item Displayed (Mobile)",
      "default": 3
    },
    {
      "type": "select",
      "id": "space_items",
      "label": "Min spacing between items",
      "default": "x",
      "options": [
        {
          "label": "t:sections.all.space_items.default",
          "value": "x"
        },
        {
          "label": "0",
          "value": "0"
        },
        {
          "label": "5px",
          "value": "5"
        },
        {
          "label": "10px",
          "value": "10"
        },
        {
          "label": "20px",
          "value": "20"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.all.section_layout.label"
    },
    {
      "type": "checkbox",
      "id": "colors_by_section",
      "label": "t:sections.all.colors.display_colors_by_section"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "visible_if": "{{ section.settings.colors_by_section == true }}"
    },
    {
      "type": "range",
      "id": "background_opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "label": "t:sections.all.background.opacity",
      "default": 0,
      "visible_if": "{{ section.settings.colors_by_section == true }}"
    },
    {
      "type": "select",
      "id": "section_layout",
      "label": "t:sections.all.section_layout.width.label",
      "options": [
        {
          "value": "container",
          "label": "t:sections.all.section_layout.width.container"
        },
        {
          "value": "wrapper_container",
          "label": "t:sections.all.section_layout.width.wrapper_container"
        },
        {
          "value": "full_width",
          "label": "t:sections.all.section_layout.width.full_width"
        }
      ],
      "default": "container"
    },
    {
      "type": "image_picker",
      "id": "section_background",
      "label": "t:sections.all.background.image"
    },
    {
      "type": "checkbox",
      "id": "hdt_background_parallax",
      "label": "Using parallax for background",
      "visible_if": "{{ section.settings.section_background != blank }}",
      "default": false
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_spacing"
    },
    {
      "type": "text",
      "id": "mg",
      "label": "Margin",
      "info": "Margin top, margin right, margin bottom, margin left. If you not use to blank",
      "default": ",,50px,",
      "placeholder": ",,50px,"
    },
    {
      "type": "text",
      "id": "mg_mb",
      "label": "Margin (Mobile)",
      "default": ",,30px,",
      "placeholder": ",,50px,",
      "visible_if": "{{ section.settings.mg != blank }}"
    },
    {
      "type": "text",
      "id": "pd",
      "label": "Padding",
      "info": "Padding top, padding right, padding bottom, padding left. If you not use to blank",
      "placeholder": "50px,,50px,"
    },
    {
      "type": "text",
      "id": "pd_mb",
      "label": "Padding (Mobile)",
      "placeholder": ",,50px,",
      "visible_if": "{{ section.settings.pd != blank }}"
    }
  ],
  "blocks": [
    {
      "type": "_category"
    },
    {
      "type": "section-heading"
    }
  ],
  "presets": [
    {
      "name": "Categories",
      "category": "t:sections_categories.03_collections.name",
      "settings": {
      },
      "blocks": [
        {
          "type": "section-heading",
          "id": "categories",
          "static": true,
          "settings": {
            "alignment": "center"
          },
          "blocks": [
            {
              "type": "_heading_section",
              "settings": {
                "heading": "<h4>Categories</h4>",
                "heading_size": "h4",
              }
            }
          ]
        }
      ]
    }
  ]
}
{% endschema %}
