<!-- section/featured-product-masonry.liquid -->

{%- liquid
  #Section layout
  assign sizes  = '(min-width: 1150px) ' | append: settings.page_width | append: 'px,(min-width: 750px) calc(100vw - 60px), calc(100vw - 30px)'

  case section.settings.section_layout 
    when 'container'
      assign parent = 'hdt-container'
      assign child  = 'hdt-section-spacing hdt-s-gradient hdt-relative' | append: ' hdt-section-spacing-' | append: section.id
    when 'wrapper_container'
      assign parent = 'hdt-section-spacing hdt-s-gradient hdt-relative' | append: ' hdt-section-spacing-' | append: section.id
      assign child  = 'hdt-container'
    when 'full_width'
      assign parent = 'hdt-container-full hdt-section-spacing hdt-s-gradient hdt-relative' | append: ' hdt-section-spacing-' | append: section.id
      assign child  = ''
      assign sizes  = '100vw'
  endcase
-%}
{{ 'hdt-banner.css' | asset_url | stylesheet_tag }}
{%- style -%}
  {% render 'spacing-vars', box: section %}
  #shopify-section-{{section.id}} {
    --masonry-grid-row-height: {{section.settings.row_height}}px;
    --masonry-grid-row-height-mb: {{section.settings.row_height_mb}}px;
  }
  #shopify-section-{{section.id}} .hdt-card-product__media-wrapp.hdt-ratio {
    --ratio-percent: calc({{ section.settings.row_height_mb }}px * var(--item-row-span-mb, 1) + var(--spacing-y) * (var(--item-row-span-mb, 1) - 1));
  }
  @media (min-width: 768px) and (max-width: 1150px) {
    #shopify-section-{{section.id}} .hdt-card-product__media-wrapp.hdt-ratio {
      --ratio-percent: calc({{ section.settings.row_height | times: 0.75 }}px * var(--item-row-span, 1) + var(--spacing-y) * (var(--item-row-span, 1) - 1));
    }
    .hdt-product-masonry .hdt-card-product__info {
      display: none;
    }
  }
  @media (min-width: 1151px) {
    #shopify-section-{{section.id}} .hdt-card-product__media-wrapp.hdt-ratio {
      --ratio-percent: calc({{ section.settings.row_height }}px * var(--item-row-span, 1) + var(--spacing-y) * (var(--item-row-span, 1) - 1));
    }
  }
  @media (prefers-reduced-motion: no-preference) {
      .js hdt-reval-items[reveal-on-scroll=true].hdt-banner_masonry :where(.hdt-card-product) {
          opacity: 1;
      }
  }
{%- endstyle -%}
<div class="{{ parent }} hdt-banner-wrapper  {% if section.settings.hdt_background_parallax %} hdt-animate--parallax-bg {% endif %}" {%- if section.settings.colors_by_section %} color-scheme="{{ section.settings.color_scheme }}" style="--background-opacity: {{ section.settings.background_opacity }};"{%- endif %}>
  <div class="hdt-banner_wrap {{ child }}">
    {%- if section.settings.section_background != blank -%}
      {% liquid
        assign image = section.settings.section_background
      %}
      {{ image | image_url: width: image.width | image_tag: width: image.width, height: image.height, sizes: sizes, widths: '200,300,400,500,600,700,800,900,1000,1100,1200,1300,1400,1500,1600,1700,1800,1900,2000', loading: 'lazy', class: 'hdt-section-background hdt-absolute hdt-top-0 hdt-left-0 hdt-w-full hdt-h-full hdt-pe-none hdt-object-cover hdt-object-center' }}
    {%- endif -%}
    {%- if section.settings.collection != blank -%}
      {%- assign collection = collections[section.settings.collection] -%}
      {%- paginate collection.products by section.settings.products_count -%}
        <hdt-reval-items reveal-on-scroll="true" id="products-{{ section.id }}-{{ section.settings.collection.id }}" scroll-into-view selector=".hdt-banner_masonry__item" class="hdt-banner_masonry hdt-row-grid hdt-grid-cols-12" style="--spacing-y: var(--spacing-x, 0px)">
            {% liquid
              assign color_list = 'products.theme_settings.color' | t | downcase | strip | replace: ' ,', ',' | replace: ', ', ',' | split: ',' | uniq
              assign size_list = 'products.theme_settings.size' | t | downcase | strip | replace: ' ,', ',' | replace: ', ', ',' | split: ',' | uniq
              assign active_items = section.settings.active_item | default: '2,9'
              for product in collection.products
                assign index_active = forloop.index0 | plus: paginate.current_page 

                if active_items contains index_active
                  assign col_w = '6'
                  assign col_w_mb = '12'
                  assign row_count = '2'
                  assign row_count_mb = '2'
                else
                  assign col_w = '3'
                  assign col_w_mb = '6'
                  assign row_count = '1'
                  assign row_count_mb = '1'
                endif  
                render 'product-card-masonry', product: product, col_w: col_w, col_w_mb: col_w_mb, row_count: row_count, row_count_mb: row_count_mb, show_vendor: section.settings.show_vendor,sizes: sizes, color_list: color_list, size_list: size_list
              endfor
            %}
        </hdt-reval-items>
        {%- if section.settings.pagination %}
          {%-liquid
            if template.name == 'collection'
              assign collection_url = ''
            else 
              assign collection_url = collection.url
            endif
          -%}
          {%- if paginate.next -%}
            {{ 'hdt-pagination.css' | asset_url | stylesheet_tag }}
            {%- if section.settings.pagination_type == "view_all" -%}
              <div class="hdt-pagination-wrapper hdt-prs-footer hdt-pagination-{{ section.settings.pagination_type }} hdt-flex hdt-justify-{{ section.settings.paginate_pos }}" timeline hdt-reveal="slide-in" style="--pagination-distance:{{ section.settings.dis_pagination }}px;">
                <a class="hdt-view-all-btn hdt-btn hdt-oh hdt-inline-flex hdt-align-center hdt-justify-center hdt-relative hdt-btn-{{ section.settings.btn_style }} hdt-btn--size-{{ section.settings.size }} hdt-font-{{ section.settings.btn_fw }}" href="{{ collection.url | default: routes.all_products_collection_url }}" hdt-reveal="slide-in" timeline>
                  {% assign view_all_df = 'general.pagination.view_all' | t %}
                  <span>{{ section.settings.btn_label | default: view_all_df | escape }}</span>
                  {%- if section.settings.enable_btn_icon -%}
                    <svg id="t4s-icon-btn" viewBox="0 0 14 10" fill="none">
                      <path fill-rule="evenodd" clip-rule="evenodd" d="M8.537.808a.5.5 0 01.817-.162l4 4a.5.5 0 010 .708l-4 4a.5.5 0 11-.708-.708L11.793 5.5H1a.5.5 0 010-1h10.793L8.646 1.354a.5.5 0 01-.109-.546z" fill="currentColor"></path>
                    </svg>
                  {%- endif -%}
                </a>
              </div>
            {%- elsif section.settings.pagination_type == "load_more" -%} 
              <div loadmore-btn-wrapp class="hdt-pagination-wrapper hdt-prs-footer hdt-pagination-{{ section.settings.pagination_type }} hdt-flex hdt-justify-{{ section.settings.paginate_pos }}" style="--pagination-distance:{{ section.settings.dis_pagination }}px;">
                <wrapp-hdt-lm-url class="hdt-contents">
                  <a section-id="{{ section.id }}" append="products-{{ section.id }}-{{ section.settings.collection.id }}" href="{{ paginate.next.url | prepend: collection_url }}" class="hdt-loamore-btn hdt-btn hdt-oh hdt-relative hdt-inline-flex hdt-align-center hdt-justify-center hdt-btn--size-{{ section.settings.size }} {{ section.settings.text_size }} hdt-font-{{ section.settings.btn_fw }}" hdt-reveal="slide-in" timeline>
                    {% assign loadmore_df = 'general.pagination.load_more_products' | t %}
                    <span>{{ section.settings.btn_label | default: loadmore_df | escape }}</span>
                    {%- if section.settings.enable_btn_icon -%}
                      <svg class="t4s-btn-icon" viewBox="0 0 32 32" width="32"><path d="M 15 4 L 15 24.0625 L 8.21875 17.28125 L 6.78125 18.71875 L 15.28125 27.21875 L 16 27.90625 L 16.71875 27.21875 L 25.21875 18.71875 L 23.78125 17.28125 L 17 24.0625 L 17 4 Z"/></svg>
                    {%- endif -%}
                  </a>
                </wrapp-hdt-lm-url>
              </div>
            {%- endif -%} 
          {%- endif -%}
        {%- endif -%}
      {%- endpaginate -%}
    {% else %}
      <div class="hdt-banner_masonry hdt-row-grid hdt-grid-cols-2 md:hdt-grid-cols-12" style="--spacing-y: var(--spacing-x, 0px)">
        {% content_for "blocks" %}
      </div>
    {% endif %}
  </div>
</div>
