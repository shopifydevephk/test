<!-- section/quick-order-list.liquid -->
{{ 'hdt-pagination.css' | asset_url | stylesheet_tag }}
{%- unless product.has_only_default_variant or product.variants.size == 1 or product.available == false -%}
  {% style %}
    {% render 'spacing-vars', box: section %}
  {% endstyle %}
  {{ 'hdt-quick-order-list.css' | asset_url | stylesheet_tag }}
  {% # theme-check-disable %}
  {%-liquid
    assign items_in_cart = cart | line_items_for: product | sum: 'quantity'
    assign show_image = section.settings.show_image
    if settings.currency_code_enabled
      assign total_variant_in_cart = cart | line_items_for: product | sum: 'original_line_price' | money_with_currency
    else
      assign total_variant_in_cart = cart | line_items_for: product | sum: 'original_line_price' | money
    endif
  -%}
  {% # theme-check-enable %}
{%- paginate product.variants by section.settings.variants_per_page -%}
  <div main-content class="hdt-s-gradient hdt-section-spacing hdt-section-spacing-{{ section.id }}" color-scheme="{{ section.settings.color_scheme }}">
    <hdt-quick-order-list id="hdt-quick-order-list-{{ section.id }}" data-section-id="{{ section.id }}" data-section-id="{{ section.id }}" data-url="{{ product.url }}" data-current-page="{{ paginate.current_page | default: 1 }}" class="hdt-container hdt-block">
      <div class="hdt-qol-head hdt-row-flex hdt-flex-cols-1 md:hdt-flex-cols-4">
        <div class="hdt-col hdt-hidden md:hdt-block"> <p class="hdt-s-text2 hdt-text-lg hdt-font-semibold hdt-text-start">{{ 'sections.quick_order_list.variant' | t }}</p></div>
        <div class="hdt-col hdt-hidden md:hdt-block"><p class="hdt-s-text2 hdt-text-lg hdt-font-semibold hdt-text-start">{{ 'sections.quick_order_list.quantity' | t }}</p></div>
        <div class="hdt-col hdt-hidden md:hdt-block"> <p class="hdt-s-text2 hdt-text-lg hdt-font-semibold hdt-text-end">{{ 'sections.quick_order_list.price' | t }}</p></div>
        <div class="hdt-col hdt-hidden md:hdt-block"><p class="hdt-s-text2 hdt-text-lg hdt-font-semibold hdt-text-end">{{ 'sections.quick_order_list.variant_total' | t }}</p></div>
        <div class="hdt-col hdt-block md:hdt-hidden">
          <p class="hdt-s-text2 hdt-text-lg hdt-font-semibold hdt-text-start">{{ 'sections.quick_order_list.variants' | t }}</p>
        </div>
      </div>
      <div class="hdt-qol-content">
        <form action="{{ routes.cart_update_url }}" method="post" id="QuickOrderList">
          <div class="quick-order-list__container hdt-ratio--{{ section.settings.image_ratio }}{% unless section.settings.image_size %} hdt-ratio--contain{% endunless %} hdt-qol-showimage-{{ show_image }}" id="hdt-main-variant-items">
            
            <table class="hdt-quick-order-list__table hdt-w-full">
              {%- assign quick_order_list_id = 'quick-order-list-items-' | append: section.id -%}
              <tbody id="{{ quick_order_list_id }}">
                {%-liquid
                  for variant in product.variants
                    if variant.available == false
                      #continue
                    endif
                    assign image = variant.image | default: product.featured_media
                    render 'hdt-quick-order-list-row', variant: variant, image: image, product: product, show_image: show_image, image_ratio: section.settings.image_ratio
                  endfor
                -%}
              </tbody>
            </table>
            {%- if paginate.pages > 1 -%}
              {%- render 'pagination', paginate: paginate, anchor: '', section_id: section.id, pagination_type: 'links', append_id: quick_order_list_id, load_more_label: 'items', paginate_pos: 'center', dis_pagination: section.settings.dis_pagination -%}
            {%- endif -%}
            
          </div>
        </form>
        <div id="hdt-quick-order-list-total">
          <div class="hdt-total_wrap hdt-row-flex hdt-flex-cols-2 md:hdt-flex-cols-4">
            <div class="hdt-total-item hdt-col md:hdt-text-start hdt-hidden md:hdt-block">
              <div class="hdt-total-item_inner hdt-flex hdt-align-center hdt-s-text2 hdt-font-normal hdt-text-base">
                <span class="hdt-btn-loading__svg">
                  <span class="hdt-qol-text" update_items_in_cart {% if items_in_cart > 0 %}qty-cart-show{% endif %}> {{ items_in_cart }}</span>
                  <span class="hdt-loading__spinner hdt-absolute" hidden>
                    <svg width="16" height="16" class="hdt-svg-spinner" focusable="false" role="presentation" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg"><circle class="hdt-path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle></svg>
                  </span>
                </span>
                <p>{{ 'sections.quick_order_list.total_items' | t }}</p>
              </div>
            </div>
            <div class="hdt-col hdt-hidden md:hdt-block"></div>
            <div class="hdt-total-price hdt-col hdt-text-end">
              <div class="hdt-totals__variant-total">
                <span class="hdt-totals__subtotal-value hdt-btn-loading__svg">
                  <span class="hdt-qol-text hdt-money hdt-text-lg hdt-font-{{ settings.pr_price_weight }} hdt-s-text2" update_items_price_in_cart>{{ total_variant_in_cart }}</span>
                  <span class="hdt-loading__spinner hdt-absolute" hidden>
                    <svg width="16" height="16" class="hdt-svg-spinner" focusable="false" role="presentation" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg"><circle class="hdt-path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle></svg>
                  </span>
                </span>
                <div class="hdt-total-item_inner hdt-flex hdt-align-center hdt-justify-end hdt-s-text2 hdt-font-normal hdt-text-base md:hdt-hidden" style="width: unset;">
                  <span class="hdt-btn-loading__svg">
                    <span class="hdt-qol-text" update_items_in_cart> {{ items_in_cart }}</span>
                    <span class="hdt-loading__spinner hdt-absolute" hidden>
                      <svg width="16" height="16" class="hdt-svg-spinner" focusable="false" role="presentation" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg"><circle class="hdt-path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle></svg>
                    </span>
                  </span>
                  <p>{{ 'sections.quick_order_list.total_items' | t }}</p>
                </div>
                <p class="hdt-totals__subtotal hdt-s-text2 hdt-font-normal hdt-text-base hdt-hidden">{{ 'sections.quick_order_list.product_subtotal' | t }}</p>
              </div>
              <small class="hdt-rte hdt-s-text2 hdt-font-normal hdt-text-base">
                {%- if cart.taxes_included and shop.shipping_policy.body != blank -%}
                  {{ 'sections.cart.taxes_included_and_shipping_policy_html' | t: link: shop.shipping_policy.url }}
                {%- elsif cart.taxes_included -%}
                  {{ 'sections.cart.taxes_included_but_shipping_at_checkout' | t }}
                {%- elsif shop.shipping_policy.body != blank -%}
                  {{ 'sections.cart.taxes_and_shipping_policy_at_checkout_html' | t: link: shop.shipping_policy.url }}
                {%- else -%}
                  {{ 'sections.cart.taxes_and_shipping_at_checkout' | t }}
                {%- endif -%}
              </small>
            </div>
            <div class="hdt-viewcart hdt-col hdt-order-first md:hdt-text-start">
              <div class="hdt-hidden hdt-flex-col hdt-viewcart-inner">
                <a href="{{ routes.cart_url }} " class="hdt-btn hdt-btn-solid hdt-font-semibold hdt-text-base hdt-relative hdt-oh hdt-inline-flex hdt-align-center hdt-justify-center">
                  <span class="hdt-btn-text">{{ 'sections.quick_order_list.view_cart' | t }}</span>
                </a>
                <hdt-quick-order-list-remove-all-button>
                  <button>{{ 'sections.quick_order_list.remove_all' | t }}</button>
                </hdt-quick-order-list-remove-all-button>
              </div>
            </div>
          </div>
          <script type="application/json" data-cart-contents>
            {{- cart | line_items_for: product | map: "variant_id" | json -}}
          </script>
        </div>
      </div>
    </hdt-quick-order-list>
  </div>
{%- endpaginate -%}
  <script type="module" src="{{ 'facets.min.js' | asset_url }}"></script>
{%- endunless -%}

{% schema %}
{
  "name": "t:sections.quick_order_list.name",
  "class": "hdt-qol hdt-section",
  "tag": "section",
  "limit": 1,
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.quick_order_list.settings.notes.label"
    },
    {
      "type": "paragraph",
      "content": "t:sections.quick_order_list.settings.notes.content"
    },
    {
      "type": "header",
      "content": "t:sections.quick_order_list.settings.variants_settings.label"
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "default": true,
      "label": "t:sections.quick_order_list.settings.variants_settings.show_image.label"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt_image",
          "label": "t:sections.all.images.ratio.adapt_image.label"
        },
        {
          "value": "square",
          "label": "t:sections.all.images.ratio.square.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.all.images.ratio.portrait.label"
        },
        {
          "value": "asos",
          "label": "t:sections.all.images.ratio.asos.label"
        },
        {
          "value": "landscape",
          "label": "t:sections.all.images.ratio.landscape.label"
        },
        {
          "value": "custom-pr",
          "label": "t:sections.all.images.ratio.custom.label"
        }
      ],
      "label": "t:sections.all.images.ratio.label",
      "default": "adapt_image",
      "visible_if": "{{ section.settings.show_image }}"
    },
    {
      "type": "checkbox",
      "id": "image_size",
      "label": "t:sections.all.images.size.cover",
      "default": true,
      "visible_if": "{{ section.settings.show_image }}"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.quick_order_list.settings.variants_settings.color"
    },
    {
      "type": "header",
      "content": "t:sections.all.pagination.header.label"
    },
    {
      "type": "range",
      "id": "variants_per_page",
      "min": 1,
      "max": 100,
      "step": 1,
      "label": "t:sections.all.limit",
      "default": 15
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_spacing"
    },
    {
      "type": "text",
      "id": "mg",
      "label": "Margin",
      "info": "Margin top, margin right, margin bottom, margin left. If you not use to blank",
      "default": ",,50px,",
      "placeholder": ",,50px,"
    },
    {
      "type": "text",
      "id": "mg_mb",
      "label": "Margin (Mobile)",
      "default": ",,30px,",
      "placeholder": ",,50px,",
      "visible_if": "{{ section.settings.mg != blank }}"
    },
    {
      "type": "text",
      "id": "pd",
      "label": "Padding",
      "info": "Padding top, padding right, padding bottom, padding left. If you not use to blank",
      "placeholder": "50px,,50px,"
    },
    {
      "type": "text",
      "id": "pd_mb",
      "label": "Padding (Mobile)",
      "placeholder": ",,50px,",
      "visible_if": "{{ section.settings.pd != blank }}"
    }
  ],
  "presets": [
    {
      "name": "t:sections.quick_order_list.name"
    }
  ]
}
{% endschema %}
