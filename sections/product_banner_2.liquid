<!-- sections/banners.liquid -->

{%- liquid
  #Section layout
  assign sizes  = '(min-width: 1150px) ' | append: settings.page_width | append: 'px,(min-width: 750px) calc(100vw - 60px), calc(100vw - 30px)'
  case section.settings.section_layout 
    when 'container'
      assign parent = 'hdt-container'
      assign child  = 'hdt-section-spacing hdt-s-gradient hdt-relative' | append: ' hdt-section-spacing-' | append: section.id
    when 'wrapper_container'
      assign parent = 'hdt-section-spacing hdt-s-gradient hdt-relative' | append: ' hdt-section-spacing-' | append: section.id
      assign child  = 'hdt-container'
    when 'full_width'
      assign parent = 'hdt-container-full hdt-section-spacing hdt-s-gradient hdt-relative' | append: ' hdt-section-spacing-' | append: section.id
      assign child  = ''
      assign sizes  = '100vw'
  endcase
-%}
{{ 'hdt-banner.css' | asset_url | stylesheet_tag }}
{%- style -%}
  {% render 'spacing-vars', box: section %}
  #shopify-section-{{ section.id }} {
    {% if section.settings.image_height_mb == 'fixed' %}
      --aspect-ratioapt:{{ section.settings.fixed_height_mb }}px;
    {% endif %}
    {% if section.settings.image_height == 'fixed' %}
      --aspect-ratioapt-md:{{ section.settings.fixed_height }}px;
    {% endif %}
    {% if section.settings.image_height == 'fit-content' %}
      @media (width > 767px){
        .hdt-slider__slide{
          height: 100%;
        }
        .hdt-banner__item{
          height: 100%;
          --media-overlap-content-h: 100%;
          .hdt-media-overlap-content>:is(picture,.hdt-media-wrapper) :is(img,video,iframe,svg){
            position: absolute;
          }
        }
      }
    {% endif %}
    .hdt-text-warry{
      margin-bottom: 10px;
    }
  }
{%- endstyle -%}
<div id="{{ section.id }}" class="{{ parent }} {% if section.settings.hdt_background_parallax %} hdt-animate--parallax-bg {% endif %}" {%- if section.settings.colors_by_section %} color-scheme="{{ section.settings.color_scheme }}" style="--background-opacity: {{ section.settings.background_opacity }};"{%- endif %}>
  <div class="{{ child }}">
    {%- if section.settings.section_background != blank -%}
      {% liquid
        assign image = section.settings.section_background
      %}
      {{ image | image_url: width: image.width | image_tag: width: image.width, height: image.height, sizes: sizes, widths: '200,300,400,500,600,700,800,900,1000,1100,1200,1300,1400,1500,1600,1700,1800,1900,2000', loading: 'lazy', class: 'hdt-section-background hdt-absolute hdt-top-0 hdt-left-0 hdt-w-full hdt-h-full hdt-pe-none hdt-object-cover hdt-object-center' }}
    {%- endif -%}
    <div class="hdt-banner-row hdt-grid-system hdt-grid-system-12">
      <div class="hdt-g-col hdt-g-col-12 md:hdt-g-col-6 lg:hdt-g-col-{{ section.settings.hdt_banner_width }}">
        {% content_for 'block', type: '_banner-item', id: 'banner-item-2' %}
      </div>
      <div class="hdt-products-wrap hdt-g-col hdt-g-col-12 md:hdt-g-col-6 lg:hdt-g-col-{{ 12 | minus: section.settings.hdt_banner_width }} {% if section.settings.show_on_title %} hdt-navigation-on-title{% endif %}">
        {% content_for 'block', type: 'section-heading', id: 'banner-heading-2' %}
        {% content_for "blocks" %}
      </div>
    </div>
  </div>
</div>
{% schema %}
  {
    "name": "Product with banner 2",
    "class": "hdt-banner hdt-section section-allow-transparent",
    "disabled_on": {
      "groups": [
        "*"
      ]
    },
    "blocks": [
      {
        "type": "_product-carousel"
      },
      {
        "type": "_product-grid"
      }
    ],
    "max_blocks": 1,
    "settings": [
      {
        "type": "checkbox",
        "id": "show_on_title",
        "label": "Show navigation on title",
        "default": false,
        "info": "Only work with product carousel",
      },
      {
        "type": "header",
        "content": "t:sections.banner.headers.label"
      },
      {
        "type": "select",
        "id": "image_height",
        "options": [
          {
            "value": "adapt_image",
            "label": "t:sections.slideshow.settings.image_height.options__2.label"
          },
          {
            "value": "full",
            "label": "t:sections.slideshow.settings.image_height.options__3.label"
          },
          {
            "value": "fixed",
            "label": "t:sections.slideshow.settings.image_height.options__4.label"
          },
          {
            "value": "fit-content",
            "label": "Fit"
          }
        ],
        "default": "fit-content",
        "label": "t:sections.slideshow.settings.image_height.label",
        "info": "t:sections.slideshow.settings.image_height.info"
      },
      {
        "type": "range",
        "id": "fixed_height",
        "min": 200,
        "max": 1000,
        "step": 10,
        "unit": "px",
        "label": "t:sections.slideshow.settings.fixed_height.label",
        "default": 860,
        "visible_if": "{{ section.settings.image_height == 'fixed' }}"
      },
      {
        "type": "select",
        "id": "image_height_mb",
        "options": [
          {
            "value": "adapt_image",
            "label": "t:sections.slideshow.settings.image_height.options__2.label"
          },
          {
            "value": "full",
            "label": "t:sections.slideshow.settings.image_height.options__3.label"
          },
          {
            "value": "fixed",
            "label": "t:sections.slideshow.settings.image_height.options__4.label"
          },
        ],
        "default": "adapt_image",
        "label": "t:sections.slideshow.settings.image_height_mb.label"
      },
      {
        "type": "range",
        "id": "fixed_height_mb",
        "min": 100,
        "max": 1000,
        "step": 10,
        "unit": "px",
        "label": "t:sections.slideshow.settings.fixed_height_mb.label",
        "default": 300,
        "visible_if": "{{ section.settings.image_height_mb == 'fixed' }}"
      },
      {
        "type": "header",
        "content": "t:sections.all.section_layout.label"
      },
      {
        "type": "range",
        "id": "hdt_banner_width",
        "label": "Banner width",
        "min": 1,
        "max": 12,
        "step": 1,
        "default": 6,
        "unit": "col",
        "info": "Banner width on desktop"
      },
      {
        "type": "checkbox",
        "id": "colors_by_section",
        "label": "t:sections.all.colors.display_colors_by_section"
      },
      {
        "type": "color_scheme",
        "id": "color_scheme",
        "label": "t:sections.all.colors.label",
        "visible_if": "{{ section.settings.colors_by_section == true }}"
      },
      {
        "type": "range",
        "id": "background_opacity",
        "min": 0,
        "max": 1,
        "step": 0.1,
        "label": "t:sections.all.background.opacity",
        "default": 0,
        "visible_if": "{{ section.settings.colors_by_section == true }}"
      },
      {
        "type": "select",
        "id": "section_layout",
        "label": "t:sections.all.section_layout.width.label",
        "options": [
          {
            "value": "container",
            "label": "t:sections.all.section_layout.width.container"
          },
          {
            "value": "wrapper_container",
            "label": "t:sections.all.section_layout.width.wrapper_container"
          },
          {
            "value": "full_width",
            "label": "t:sections.all.section_layout.width.full_width"
          }
        ],
        "default": "container"
      },
      {
        "type": "image_picker",
        "id": "section_background",
        "label": "t:sections.all.background.image"
      },
    {
      "type": "checkbox",
      "id": "hdt_background_parallax",
      "label": "Using parallax for background",
      "visible_if": "{{ section.settings.section_background != blank }}",
      "default": false
    },
      {
        "type": "header",
        "content": "t:sections.all.padding.section_spacing"
      },
      {
        "type": "text",
        "id": "mg",
        "label": "Margin",
        "info": "Margin top, margin right, margin bottom, margin left. If you not use to blank",
        "default": ",,50px,",
        "placeholder": ",,50px,"
      },
      {
        "type": "text",
        "id": "mg_mb",
        "label": "Margin (Mobile)",
        "default": ",,30px,",
        "placeholder": ",,50px,",
        "visible_if": "{{ section.settings.mg != blank }}"
      },
      {
        "type": "text",
        "id": "pd",
        "label": "Padding",
        "info": "Padding top, padding right, padding bottom, padding left. If you not use to blank",
        "placeholder": "50px,,50px,"
      },
      {
        "type": "text",
        "id": "pd_mb",
        "label": "Padding (Mobile)",
        "placeholder": ",,50px,",
        "visible_if": "{{ section.settings.pd != blank }}"
      }
    ],
    "presets": [
      {
        "name": "Product with banner 2",
        "category": "t:sections_categories.02_banner.name",
        "blocks": [
          {
            "type": "_banner-item",
            "static": true,
            "id": "banner-item-2",
            "blocks": [
              {
                "type": "heading",
                "settings": {
                  "heading": "<h5>LOOKBOOK 2025</h5>",
                  "heading_size": "h4"
                }
              },
              {
                "type": "text",
                "settings": {
                  "text": "<p>MAKE LOVE THIS LOOK</p>"
                }
              }
            ]
          },
          {
            "type": "_product-carousel",
            "settings": {
              "col_dk": "4",
              "col_tb": "3",
              "col_mb": "2",
            }
          },
        ]
      }
    ]
  }
{% endschema %}
