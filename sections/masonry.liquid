  width: auto;
}
 {% endcomment %}
<packery-layout class="hdt-block hdt-container hdt-oh" layout="[data-layout]" selector="[item-selector]">
  <div data-layout class="hdt-packery-layout hdt-gutter-8 md:hdt-gutter-10 lg:hdt-gutter-30 hdt-ratio--{{ section.settings.image_ratio }}">
  {%- for product in section.settings.collection.products limit: 15 -%}
    {% assign image = product.featured_image %}
    {% if forloop.index == 2 or forloop.index == 8 %}
      {% assign class = 'hdt-custom-col-12 md:hdt-custom-col-8 lg:hdt-custom-col-6' %}
    {% else %}
      {% assign class = 'hdt-custom-col-6 md:hdt-custom-col-4 lg:hdt-custom-col-3' %}
    {% endif %}
    <div item-selector class="item {{ class }}">
      <div hdt-reveal="slide-in" timeline>
        <div class="hdt-ratio" style="--aspect-ratioapt: {{ image.aspect_ratio | default: 1.2 }};">
          {{ image | image_url: width: image.width | image_tag: loading: 'lazy', width: image.width, height: image.height, class: 'hdt-obj-eff' , sizes: sizes, widths: "360,400,600,800,1000,1200,1400,1440,1920,2000,2400,2800,3600" }}
        </div>
      </div>
    </div>
  {%- endfor -%}
  </div>
</packery-layout>
<hr>
{% comment %} <packery-layout class="hdt-contents" layout="[data-layout]" selector="hdt-card-product">
