{% schema %}
  {
    "name": "Masonry",
    "class": "hdt-packery-layout",
    "settings": [
      {
        "type": "collection",
        "id": "collection",
        "label": "Collection"
      },
      {
        "type": "select",
        "id": "product_des",
        "label": "t:sections.collection_products.settings.product_des",
        "options": [
          {
            "value": "1",
            "label": "1"
          },
          {
            "value": "2",
            "label": "2"
          },
          {
            "value": "3",
            "label": "3"
          },
          {
            "value": "4",
            "label": "4"
          },
          {
            "value": "5",
            "label": "5"
          },
          {
            "value": "6",
            "label": "6"
          },
          {
            "value": "7",
            "label": "7"
          },
          {
            "value": "8",
            "label": "8"
          },
          {
            "value": "9",
            "label": "9"
          },
          {
            "value": "10",
            "label": "10"
          }/*,
          {
            "value": "11",
            "label": "11"
          }*/
        ],
        "default": "1"
      },
      {
        "type": "range",
        "id": "products_count",
        "min": 1,
        "max": 50,
        "step": 1,
        "label": "t:sections.all.limit",
        "default": 8
      },
      {
        "type": "select",
        "id": "image_ratio",
        "options": [
          {
            "value": "adapt_image",
            "label": "t:sections.all.images.ratio.adapt_image.label"
          },
          {
            "value": "square",
            "label": "t:sections.all.images.ratio.square.label"
          },
          {
            "value": "portrait",
            "label": "t:sections.all.images.ratio.portrait.label"
          },
          {
            "value": "asos",
            "label": "t:sections.all.images.ratio.asos.label"
          },
          {
            "value": "landscape",
            "label": "t:sections.all.images.ratio.landscape.label"
          },
          {
            "value": "custom-pr",
            "label": "t:sections.all.images.ratio.custom.label"
          }
        ],
        "label": "t:sections.all.images.ratio.label",
        "default": "adapt_image"
      },
      {
        "type": "checkbox",
        "id": "image_size",
        "label": "t:sections.all.images.size.cover",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_vendor",
        "label": "t:sections.collection_products.settings.show_vendor",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "pagination",
        "label": "t:blocks.product_grid.settings.pagination.use_pagination",
        "default": true
      },
      {
        "type": "select",
        "id": "pagination_type",
        "label": "t:sections.all.load_more.type.label",
        "info": "t:sections.all.load_more.type.info",
        "options": [
          {
            "value": "view_all",
            "label": "t:sections.all.load_more.type.view_all.label"
          },
          {
            "value": "load_more",
            "label": "t:sections.all.load_more.type.load_more.label"
          }
        ],
        "default": "load_more",
        "visible_if": "{{ section.settings.pagination }}"
      },
      {
        "type": "select",
        "id": "paginate_pos",
        "label": "t:sections.all.load_more.position.label",
        "default": "center",
        "options": [
          {
            "value": "start",
            "label": "t:sections.all.load_more.position.option_1.label"
          },
          {
            "value": "center",
            "label": "t:sections.all.load_more.position.option_2.label"
          },
          {
            "value": "end",
            "label": "t:sections.all.load_more.position.option_3.label"
          }
        ],
        "visible_if": "{{ section.settings.pagination }}"
      },
      {
        "type": "range",
        "id": "dis_pagination",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:sections.all.load_more.distance.label",
        "default": 30,
        "visible_if": "{{ section.settings.pagination }}"
      },
      {
        "type": "text",
        "id": "btn_label",
        "label": "t:sections.collection_products.settings.btn_label.label",
        "info": "t:sections.collection_products.settings.btn_label.info",
