{{ 'age-verification.css' | asset_url | stylesheet_tag }}
<sys-age-verify
  color-scheme="{{ section.settings.color_scheme }}"
  configs='{"id": "{{ section.id }}", "day_next": {{ section.settings.day_next }}, "date_of_birth": {{ section.settings.date_of_birth }}, "age_limit": {{ section.settings.age_limit }}, "time_delay": {{ section.settings.time_delay }}, "day_next_show": {{ section.settings.day_next_show }} }'
  style="--background-opacity: {{ section.settings.background_opacity }};"
>
  <hdt-modal class="hdt-modal hdt-modal-age-verify hdt-contents">
    <dialog id="modalAgeVerify-{{ section.id }}" class="hdt-dialog hdt-dialog-modal" scroll-lock>
      <div class="hdt-age-verify_content hdt-dialog-modal__inner hdt-current-scrollbar">
        <div
          class="hdt-age-verify_wrap hdt-row-flex hdt-flex-cols-1 hdt-s-gradient"
          style="--spacing-x: 0px;--spacing-y: 0px;">
          <div class="hdt-col hdt-h-full">
            <div class="hdt-col-inner hdt-media-overlap-content" style="height:100%">
              {%- if section.settings.image != blank -%}
                {% liquid
                  echo '<picture class="hdt-media-wrapper">'
                  if section.settings.image_mb != blank and section.settings.image_mb != section.settings.image
                    assign srcset = section.settings.image_mb | image_url: width: section.settings.image_mb.width | image_tag: widths: '300,400,500,600,700,800', alt: null | split: 'srcset="' | last
                    unless srcset contains 'src='
                      echo '<source media="(max-width: 767px)" srcset="' | append: srcset | replace_first: 'style=', 'data-none='
                    endunless
                  endif
                  echo section.settings.image | image_url: width: section.settings.image.width | image_tag: loading: 'lazy', sizes: '(min-width: 768px) 50vw, 100vw', class: 'hdt-object-pos-mb', widths: '300,400,500,600,700,800,900,1000,1100,1200,1300,1400,1500'
                  echo '</picture>'
                %}
              {%- endif -%}

              <div class="hdt-place-self-center md:hdt-place-self-center">
                <div class="hdt-content_wrap">
                  <div class="hdt-content hdt-flex hdt-flex-col hdt-justify-center hdt-align-center hdt-text-center md:hdt-text-center">
                    {%- if section.settings.heading != blank -%}
                      <h2 class="hdt-heading-age-verify hdt-s-text hdt-font-bold hdt-mb-4">
                        {{ section.settings.heading }}
                      </h2>
                    {%- endif -%}

                    {%- if section.settings.description != blank -%}
                      <div class="hdt-description-age-verify hdt-text-base hdt-s-text hdt-mb-6">
                        {{ section.settings.description }}
                      </div>
                    {%- endif -%}

                    {% if section.settings.date_of_birth %}
                      <div class="hdt-row hdt-flex-cols-3 hdt-age_date_of_birth">
                        <div class="hdt-col hdt-col-year">
                          {%- assign now_year = 'now' | date: '%Y' | plus: 0 -%}
                          {%- assign calc_year = now_year | minus: section.settings.age_limit | plus: 1 -%}
                          <select name="ageyear" class="hdt-w-full" id="ageyear">
                            <option value="{{ now_year }}">{{ 'age_verification.year.label' | t }}</option>
                            {%- for i in (1970..calc_year) reversed %}
                              <option value="{{ i }}">{{ i }}</option>
                            {% endfor -%}
                          </select>
                        </div>
                        <div class="hdt-col hdt-col-month">
                          <select name="agemonth" class="hdt-w-full" id="agemonth">
                            <option value="">{{ 'age_verification.month.label' | t }}</option>
                            <option value="1">{{ 'age_verification.month.options.1' | t }}</option>
                            <option value="2">{{ 'age_verification.month.options.2' | t }}</option>
                            <option value="3">{{ 'age_verification.month.options.3' | t }}</option>
                            <option value="4">{{ 'age_verification.month.options.4' | t }}</option>
                            <option value="5">{{ 'age_verification.month.options.5' | t }}</option>
                            <option value="6">{{ 'age_verification.month.options.6' | t }}</option>
                            <option value="7">{{ 'age_verification.month.options.7' | t }}</option>
                            <option value="8">{{ 'age_verification.month.options.8' | t }}</option>
                            <option value="9">{{ 'age_verification.month.options.9' | t }}</option>
                            <option value="10">{{ 'age_verification.month.options.10' | t }}</option>
                            <option value="11">{{ 'age_verification.month.options.11' | t }}</option>
                            <option value="12">{{ 'age_verification.month.options.12' | t }}</option>
                          </select>
                        </div>
                        <div class="hdt-col hdt-col-day">
                          <select name="ageday" class="hdt-w-full" id="ageday" data-max-day="31">
                            <option value="">{{ 'age_verification.day.label' | t }}</option>
                            {%- for i in (1..31) %}
                              <option value="{{ i }}">{{ i }}</option>
                            {% endfor -%}
                          </select>
                          <script>
                            document.addEventListener('DOMContentLoaded', function() {
                              var monthSelect = document.getElementById('agemonth');
                              var daySelect = document.getElementById('ageday');
                              if (monthSelect && daySelect) {
                                function updateDays() {
                                  var month = parseInt(monthSelect.value, 10);
                                  var yearSelect = document.getElementById('ageyear');
                                  var year = yearSelect ? parseInt(yearSelect.value, 10) : 2000;
                                  var daysInMonth = 31;
                                  if (!isNaN(month)) {
                                    if ([4, 6, 9, 11].indexOf(month) > -1) {
                                      daysInMonth = 30;
                                    } else if (month === 2) {
                                      if (!isNaN(year) && ((year % 4 === 0 && year % 100 !== 0) || (year % 400 === 0))) {
                                        daysInMonth = 29;
                                      } else {
                                        daysInMonth = 28;
                                      }
                                    }
                                  }
                                  while (daySelect.options.length > 1) {
                                    daySelect.remove(1);
                                  }
                                  for (var i = 1; i <= daysInMonth; i++) {
                                    var opt = document.createElement('option');
                                    opt.value = i;
                                    opt.textContent = i;
                                    daySelect.appendChild(opt);
                                  }
                                }
                                monthSelect.addEventListener('change', updateDays);
                                var yearSelect = document.getElementById('ageyear');
                                if (yearSelect) {
                                  yearSelect.addEventListener('change', updateDays);
                                }
                              }
                            });
                          </script>
                        </div>
                      </div>
                    {% endif %}

                    <div class="hdt-age-verify-form hdt-w-full hdt-max-w-sm">
                      <button
                        type="button"
                        class="hdt-btn-verify hdt-px-8 hdt-py-4 hdt-font-medium hdt-text-lg"
                        data-action="verify"
                      >
                        {{ section.settings.verify_button_text | default: 'SUBMIT' }}
                      </button>

                      <button
                        type="button"
                        class="hdt-btn-exit hdt-px-8 hdt-py-4 hdt-border hdt-font-medium hdt-text-lg"
                        data-action="exit">
                        {{ section.settings.exit_button_text | default: 'CANCLE' }}
                      </button>
                    </div>
                    {%- if section.settings.legal_text != blank -%}
                      <div class="hdt-age-des hdt-text-xs hdt-mt-4 hdt-max-w-sm">
                        {{ section.settings.legal_text }}
                      </div>
                    {%- endif -%}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </dialog>
  </hdt-modal>
</sys-age-verify>

{% schema %}
{
  "name": "🔒 Age Verification",
  "tag": "section",
  "class": "hdt_age_verification",
  "limit": 1,
  "enabled_on": {
    "groups": ["custom.system"]
  },
  "settings": [
    {
      "type": "header",
      "content": "General Settings"
    },
    {
      "type": "range",
      "id": "day_next",
      "min": 1,
      "max": 30,
      "step": 1,
      "default": 1,
      "label": "Cookie storage days"
    },
    {
      "type": "checkbox",
      "id": "date_of_birth",
      "label": "Require date of birth",
      "default": false
    },
    {
      "type": "range",
      "id": "day_next_show",
      "label": "Show day next",
      "min": 1,
      "max": 100,
      "step": 1,
      "default": 1,
      "unit": "day"
    },
    {
      "type": "range",
      "id": "age_limit",
      "min": 18,
      "max": 25,
      "step": 1,
      "default": 18,
      "label": "Minimum age"
    },
    {
      "type": "range",
      "id": "time_delay",
      "min": 0,
      "max": 10,
      "step": 1,
      "default": 2,
      "label": "Display delay (seconds)"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Age Verification"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "You must be at least 18 years old to access this website. Please confirm your age."
    },
    {
      "type": "text",
      "id": "verify_button_text",
      "label": "Verify button",
      "default": "I am 18 or older"
    },
    {
      "type": "text",
      "id": "exit_button_text",
      "label": "Exit button",
      "default": "I am under 18"
    },
    {
      "type": "textarea",
      "id": "legal_text",
      "label": "Legal text",
      "default": "By clicking 'I am 18 or older', you confirm that you are old enough to access this content."
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "image_picker",
      "id": "image_mb",
      "label": "Background image (Mobile)"
    },
    {
      "type": "range",
      "id": "background_opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "label": "Background overlay",
      "default": 0,
      "visible_if": "{{ section.settings.image != blank or section.settings.image_mb != blank }}"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label"
    }
  ],
  "presets": [
    {
      "name": "🔒 Age Verification",
      "settings": {
        "day_next": 1,
        "date_of_birth": false,
        "age_limit": 18,
        "time_delay": 2,
        "heading": "Are you over 18?",
        "description": "You must be 18 years of age or older to view page. Please verify your age to enter.",
        "verify_button_text": "SUBMIT",
        "exit_button_text": "CANCLE",
        "legal_text": "",
        "color_scheme": "scheme-fe88a2ec-47a1-478d-8953-54da0178e18c",
        "background_opacity": 0
      }
    }
  ]
}
{% endschema %}
