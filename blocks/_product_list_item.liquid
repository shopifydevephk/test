<!-- blocks/_product_list_item.liquid -->
{%- liquid
  assign product = block.settings.product
  assign image = block.settings.image | default: product.featured_image
  assign title = block.settings.title | default: product.title
  assign price = block.settings.price | default: product.price
  assign desc = block.settings.desc | default: product.description
  assign default_btn_label = 'sections.featured_collection_2.shop_now' | t
  assign btn_label = block.settings.btn_label | default: default_btn_label
  assign btn_url = block.settings.btn_url | default: product.url
-%}
{% render '_product-list-item', product: product,image: image, title: title, price: price, desc: desc, btn_label: btn_label, btn_url: btn_url,show_btn: closest.show_btn %}
{% schema %}
  {
    "name": "Item",
    "tag": null,
    "settings": [
      {
        "type": "product",
        "id": "product",
        "label": "Product"
      },
      {
        "type": "paragraph",
        "content": "—————————————————"
      },
      {
        "type": "paragraph",
        "content": "All blank if getting data from product"
      },
      {
        "type": "image_picker",
        "id": "image",
        "label": "Image",
      },
      {
        "type": "text",
        "id": "title",
        "label": "Title",
      },
      {
        "type": "number",
        "id": "price",
        "label": "Price",
      },
      {
        "type": "textarea",
        "id": "desc",
        "label": "Product description",
      },
      {
        "type": "text",
        "id": "btn_label",
        "label": "Button label",
        "default": "Shop now",
      },
      {
        "type": "url",
        "id": "btn_url",
        "label": "Button URL",
      },
    ],
    "presets": [
      {
        "name": "Item"
      }
    ]
  }
{% endschema %}
