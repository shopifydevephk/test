<!-- _collection_item.liquid -->
{%- liquid
  assign current_width = settings.page_width | append: 'px'
  assign current_width_tb = '100vw'
  assign current_width_mb = '100vw'
  assign hdt_svg_image = block.settings.hdt_collection_list_svg
  assign svg_width = block.settings.svg_width
  assign svg_width_mb = block.settings.svg_width_mb
  if section.settings.space_items == "x"
    assign space_item = settings.spacing_grid_horizontal
    assign space_item_tb = settings.spacing_grid_horizontal | divided_by: 2
    assign space_item_mb = settings.spacing_grid_horizontal | divided_by: 2
  else
    assign space_item = section.settings.space_items
    assign space_item_tb = space_item | times: 0.666 | round
    assign space_item_mb = space_item | times: 0.333 | round
  endif
  if section.settings.section_layout == 'full_width'
    assign current_width = '100vw'
  endif
-%}
{%- capture sizes -%}
  {%- if section.settings.layout_mode == 'packery' -%}
    (min-width: 1150px) calc( {{ current_width }} * {{ block.settings.col_dk }} / 12 - {{ section.settings.gap_item_dk }}px / 2 ),(min-width: 768px) calc( {{ current_width_tb }} * {{ block.settings.col_tb }} / 12 - {{ section.settings.gap_item_tb }}px / 2 ), calc( {{ current_width_mb }} * {{ block.settings.col_mb }} / 12 - {{ section.settings.gap_item_mb }}px / 2 )
  {%- else -%}
  (min-width: 1150px) calc(({{ current_width }} -  ({{ space_item }} * ( {{ section.settings.col_dk }} - 1 ))) * 1 / {{ section.settings.col_dk }}),(min-width: 768px) calc( ({{ current_width_tb }} - ({{ space_item_tb }} * ( {{ section.settings.col_tb }} - 1 ))) * 1 / {{ section.settings.col_tb }}), calc( ({{ current_width_mb }} - ({{ space_item_mb }} * ( {{ section.settings.col_mb }} - 1 ) )) * 1 / {{ section.settings.col_mb }})
  {%- endif -%}
{%- endcapture -%}
{%- liquid
  render 'collection-item', block: block, hdt_svg_image: hdt_svg_image, svg_width: svg_width, svg_width_mb: svg_width_mb, collection: collections[block.settings.collection], class: "hdt-slider__slide", sizes: sizes, current: 1
-%}
