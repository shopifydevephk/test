<!-- blocks/banner-item.liquid -->
<div id="{{ block.id }}" class="hdt-banner__item md:hdt-height--{{ section.settings.image_height }} hdt-height--{{ section.settings.image_height_mb }} hdt-eff-{{ block.settings.b_effect }} hdt-eff-img-{{ block.settings.img_effect }} hdt-eff hdt-oh hdt-relative hdt-overlay" {%- if block.settings.colors_by_block %} color-scheme="{{ block.settings.color_scheme }}"{% endif %} {{ block.shopify_attributes }} style="{% render 'block-style', settings: block.settings, type: 'background_content' %}">
  {%- style -%}
  #{{ block.id }} .hdt-media-overlap-content{
    --media-overlap-content-gap-r: {{ block.settings.gap_r }}px;
    --media-overlap-content-gap-c: {{ block.settings.gap_c }}px;
  }
  @media (max-width: 1149px){
    #{{ block.id }} .hdt-media-overlap-content{
      --media-overlap-content-gap-r: {{ block.settings.gap_r_mb }}px;
      --media-overlap-content-gap-c: {{ block.settings.gap_c_mb }}px;
    }
  }
{%- endstyle -%}
  <div class="hdt-item_inner hdt-radius hdt-media-overlap-content{% if block.settings.overlay_content %} hdt-overlay-wrap{% endif %}" hdt-reveal="slide-in" timeline>
    <a class="hdt-full-width-link"  aria-label="link" {%- if block.settings.banner_url == blank %} role="link" disabled="true" {%- else %} href="{{ block.settings.banner_url }}"{% endif %} target="{% if block.settings.banner_target %}_blank{% else %}_self{% endif %}"></a>
    {% content_for 'block', type: '_media', id: 'banner-media' %}
    <div class="hdt-grid hdt-h-full{% unless request.design_mode %} hdt-pe-none{% endunless %} hdt-content-type-{{ block.settings.content_position_type }}">
      <div class="hdt-content hdt-radius hdt-place-self-{{ block.settings.content_position_mb }} md:hdt-place-self-{{ block.settings.content_position }} {% if block.settings.background_content %} hdt-background-content{% endif %}{% if block.settings.use_border_content %} hdt-content-use-border{% endif %}{% if block.settings.box_square %} hdt-content-boxsquare{% endif %}{% if block.settings.content_rounded %} hdt-radius-full{% endif %}"{% if block.settings.background_content %} reval{% endif %}>
        <div class="hdt-content-inner hdt-text-{{ block.settings.alignment_mb }} md:hdt-text-{{ block.settings.alignment }}">
          {% content_for 'blocks' %}
        </div>
      </div>
    </div>
  </div>
</div>
