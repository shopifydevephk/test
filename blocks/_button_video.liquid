<hdt-video-popup class="hdt-button-video-wrapper hdt-block hdt-z-3" action="{{ block.settings.click_action }}" data-modal-id="modal-{{ block.id }}" data-section-id="{{ section.id }}" {{ block.shopify_attributes }}>
  {%- capture style -%}
    {%- if block.settings.icon != "none" -%}--gap-btn-icon: {{ block.settings.icon_spacing }}px; --height-btn-icon: {{ block.settings.icon_height }}px;{%- endif -%}
    {%- if block.settings.size == "custom custom-inline" -%}--hdt-btn-line-height: {{ block.settings.min_height_btn }}px; font-size: {{ block.settings.font_size_btn }}px;
      {%- if block.settings.label != blank -%}
        --hdt-btn-padding-x: {{ block.settings.padding_btn }}px;--minw-button: {{ block.settings.min_width_btn }}px;--minwdt-button: {{ block.settings.min_width_dt_btn }}px;
      {%- else -%}
        --hdt-btn-padding-x: var(--spacing-1, .5313rem); --minw-button: {{ block.settings.min_height_btn }}px;--minwdt-button: {{ block.settings.min_height_btn | times: block.settings.min_width_dt_btn | divided_by: block.settings.min_width_btn }}px;
      {%- endif -%}
    {%- endif -%}
    {%- if block.settings.btn_style == 'hdt-btn-custom' -%}--hdt-btn-color: {{ block.settings.color_btn.rgb }}; --hdt-btn-hover-color: {{ block.settings.color_hover_btn.rgb }}; --hdt-btn-bg: {% if block.settings.background_btn == "rgba(0,0,0,0)" %}transparent{% else %}{{ block.settings.background_btn.rgb }}{% endif %}; --hdt-btn-hover-bg: {% if block.settings.background_hover_btn == "rgba(0,0,0,0)" %}transparent{% else %}{{ block.settings.background_hover_btn.rgb }}{% endif %};
    {% if block.settings.border_w_btn != blank %}
      --hdt-btn-border-color: {{ block.settings.border_btn.rgb }}; --hdt-btn-hover-border-color: {{ block.settings.border_hover_btn.rgb }}; --hdt-btn-border-width: {{ block.settings.border_w_btn }};
    {%- else -%}
      --hdt-btn-border-color: {{ block.settings.background_btn.rgb }}; --hdt-btn-hover-border-color: {{ block.settings.background_hover_btn.rgb }}; --hdt-btn-border-width: {{ block.settings.border_w_btn }};
    {%- endif -%}
  {%- endif -%}
  {%- endcapture -%}
  {%- capture class -%}
    hdt-button-block hdt-btn hdt-relative hdt-oh hdt-font-{{ block.settings.font_weight }} hdt-btn--size-{{ block.settings.size }} {{ block.settings.text_size }} {{ block.settings.btn_style }}{% if block.settings.boder_hover %} hdt-btn-boder-hover{% endif %}{% if block.settings.full_width %} hdt-btn-full-width{% endif %} {{ block.settings.rounded }}{% if block.settings.icon != "none" %} hdt-btn--with-icon hdt-btn--pos-icon-{{ block.settings.icon_position }}{% endif %}
  {%- endcapture -%}
  <button click-button hdt-reveal="slide-in" timeline class="{{ class }}" style="{{ style }}" {% if block.settings.open_in_new_tab %} rel="noopener noreferrer"{% endif -%} {{ block.shopify_attributes }}>  
    {%- liquid
      if block.settings.icon != 'none'
        render 'icons', icon: block.settings.icon
      endif
    -%}    
    {%- liquid
      if block.settings.label != blank
        echo '<span>'
          echo block.settings.label
        echo '</span>'
      endif
    -%}
  </button>
  <hdt-modal class="hdt-modal hdt-modal-video hdt-contents">
    <dialog id="modal-{{ block.id }}" class="hdt-dialog hdt-dialog-modal" scroll-lock>
      {% if block.settings.click_action == 'inline' and block.settings.enable_close %}
        <button close-button class="hdt-s-text hdt-dialog-btn__close" aria-label="{{ 'accessibility.close' | t | escape }}">{%- render 'icon' with 'close' -%}</button>
      {% elsif block.settings.click_action == 'popup' %}
        <button ref="closeButton" class="hdt-s-text hdt-dialog-btn__close" aria-controls="modal-{{ block.id }}" aria-label="{{ 'accessibility.close' | t | escape }}">{%- render 'icon' with 'close' -%}</button>
      {% endif %}
      <div class="hdt-dialog-modal__inner">
        {%- if block.settings.video != blank and block.settings.source == 'shopify' -%}
          <hdt-video-player autoplay id="media-{{ block.id }}">
            {{- block.settings.video | video_tag: image_size: '1500x', playsinline: true, muted: true, loop: true, controls: true, preload: 'metadata' -}}
          </hdt-video-player>
        {%- else -%}
          <hdt-video-player host="{{ block.settings.external_video_url.type }}" type="background" autoplay>
            <template>
              {%- if block.settings.external_video_url.type == 'youtube' -%}
                <iframe id="iframe-{{ block.id }}" src="https://www.youtube.com/embed/{{ block.settings.external_video_url.id }}?playsinline=1&autoplay=0&controls=1&mute=1&loop=1&playlist={{ block.settings.external_video_url.id }}&enablejsapi=1&rel=0&modestbranding=1&origin={{ 'https://' | append: request.host | url_encode }}" allow="autoplay; encrypted-media" allowfullscreen="allowfullscreen" style="width: 300px;"></iframe>
              {%- elsif block.settings.external_video_url.type == 'vimeo' -%}
                <iframe src="https://player.vimeo.com/video/{{ block.settings.external_video_url.id }}?autoplay=1&autopause=1&background=1&loop=1&muted=1&transparent=0&responsive=1&portrait=0&title=0&byline=0&color={{ settings.color_accent | remove_first: '#' }}" allow="autoplay; encrypted-media;" allowfullscreen="allowfullscreen"></iframe>
              {%- endif -%}
            </template>
          </hdt-video-player>
        {%- endif -%}
      </div>
    </dialog>
  </hdt-modal>
</hdt-video-popup>
