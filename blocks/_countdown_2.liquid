<hdt-countdown class="hdt-countdown-wrap{% if block.settings.hide_on_mobile %} hdt-hidden md:hdt-inline-block{% else %} hdt-inline-block{% endif %} hdt-size-{{ block.settings.size }} hdt-design-{{ block.settings.design }}" config='{"month":"{{ block.settings.month }}", "date":"{{ block.settings.day }}, {{ block.settings.year }} {{ block.settings.hour }}:{{ block.settings.minute }}", "hideTimerOnComplete": {{ block.settings.hide_on_complete }}, "hasZero": {{ block.settings.prepend_number }}, "hasTextPlural": true }' hdt-reveal="slide-in" timeline>
  <div class="hdt-countdown__inner hdt-block-spacing" aria-hidden="true" style="--gap: {{ block.settings.space_item }}px; --border-radius: {{ block.settings.border_radius }}%; --border-width: {{ block.settings.border_width }}px; --number-color: {{ block.settings.number_color }}; --text-color: {{ block.settings.text_color }}; --border-color: {{ block.settings.border_color }}; --background-color: {{ block.settings.background_color }};--margin-bottom: {{ block.settings.margin_bottom }}px;--margin-bottom-mobile: {{ block.settings.margin_bottom_mobile }}px;">
    <div class="hdt-countdown__item hdt-countdown--days" hdt-reveal="slide-in" timeline>
      <hdt-countdown-amount effect="{{ block.settings.effect_cd }}" class="hdt-countdown__amount" data-days>00</hdt-countdown-amount>
      <hdt-countdown-text singular="{{ 'sections.countdown_timmer.day' | t | escape }}" class="hdt-countdown__text hdt-grid">{{ 'sections.countdown_timmer.day_plural' | t }}</hdt-countdown-text>
    </div>
    <div class="hdt-countdown__item hdt-countdown--hours" hdt-reveal="slide-in" timeline>
      <hdt-countdown-amount effect="{{ block.settings.effect_cd }}" class="hdt-countdown__amount" data-hours>00</hdt-countdown-amount>
      <hdt-countdown-text singular="{{ 'sections.countdown_timmer.hr' | t | escape }}" class="hdt-countdown__text hdt-grid">{{ 'sections.countdown_timmer.hr_plural' | t }}</hdt-countdown-text>
    </div>
    <div class="hdt-countdown__item hdt-countdown--minutes" hdt-reveal="slide-in" timeline>
      <hdt-countdown-amount effect="{{ block.settings.effect_cd }}" class="hdt-countdown__amount" data-minutes>00</hdt-countdown-amount>
      <hdt-countdown-text singular="{{ 'sections.countdown_timmer.min' | t | escape }}" class="hdt-countdown__text hdt-grid">{{ 'sections.countdown_timmer.min_plural_mini' | t }}</hdt-countdown-text>
    </div>
    <div class="hdt-countdown__item hdt-countdown--seconds" hdt-reveal="slide-in" timeline>
      <hdt-countdown-amount effect="{{ block.settings.effect_cd }}" class="hdt-countdown__amount" data-seconds>00</hdt-countdown-amount>
      <hdt-countdown-text singular="{{ 'sections.countdown_timmer.sec' | t | escape }}" class="hdt-countdown__text hdt-grid">{{ 'sections.countdown_timmer.sec_plural_mini' | t }}</hdt-countdown-text>
    </div>
  </div>
  {%- if block.settings.mess_complete != blank %}<div class="hdt-countdown__message hdt-hidden hdt-s-text">{{ block.settings.mess_complete }}</div>{% endif -%}
</hdt-countdown>

{% schema %}
  {
    "name": "t:blocks.countdown_timer.name",
    "class": "hdt-countdown-timer",
    "settings": [
      {
        "type": "number",
        "id": "year",
        "default": 2030,
        "label": "t:blocks.countdown_timer.settings.year.label",
        "info": "t:blocks.countdown_timer.settings.year.info"
      },
      {
        "type": "range",
        "id": "month",
        "min": 1,
        "max": 12,
        "step": 1,
        "default": 4,
        "label": "t:blocks.countdown_timer.settings.month.label"
      },
      {
        "type": "range",
        "id": "day",
        "min": 1,
        "max": 31,
        "step": 1,
        "default": 19,
        "label": "t:blocks.countdown_timer.settings.day.label"
      },
      {
        "type": "range",
        "id": "hour",
        "min": 0,
        "max": 23,
        "step": 1,
        "default": 12,
        "label": "t:blocks.countdown_timer.settings.hour.label"
      },
      {
        "type": "range",
        "id": "minute",
        "min": 0,
        "max": 59,
        "step": 1,
        "default": 0,
        "label": "t:blocks.countdown_timer.settings.minute.label"
      },
      {
        "type": "select",
        "id": "design",
        "label": "t:blocks.countdown_timer.settings.design.label",
        "options": [
          {
          "value": "1",
          "label": "t:blocks.countdown_timer.settings.design.options__1.label"
          },
          {
            "value": "2",
            "label": "t:blocks.countdown_timer.settings.design.options__2.label"
          }
        ],
        "default": "1"
      },
      {
        "type": "select",
        "id": "size",
        "label": "t:blocks.countdown_timer.settings.size.label",
        "options": [
          {
            "value": "small",
            "label": "t:blocks.countdown_timer.settings.size.options__1.label"
          },
          {
            "value": "medium",
            "label": "t:blocks.countdown_timer.settings.size.options__2.label"
          },
          {
            "value": "large",
            "label": "t:blocks.countdown_timer.settings.size.options__3.label"
          },
          {
            "value": "xlarge",
            "label": "t:blocks.countdown_timer.settings.size.options__4.label"
          }
        ],
        "default": "medium"
      },
      {
        "type": "range",
        "id": "border_radius",
        "min": 0,
        "max": 50,
        "step": 1,
        "unit": "%",
        "label": "t:blocks.countdown_timer.settings.border_radius.label",
        "default": 50
      },
      {
        "type": "range",
        "id": "border_width",
        "min": 0,
        "max": 5,
        "step": 1,
        "unit": "px",
        "label": "t:blocks.countdown_timer.settings.border_width.label",
        "default": 5
      },
      {
        "type": "range",
        "id": "space_item",
        "min": 0,
        "max": 30,
        "step": 1,
        "unit": "px",
        "label": "t:blocks.countdown_timer.settings.space_item.label",
        "default": 15
      },
     
      {
        "type": "select",
        "id": "effect_cd",
        "label": "t:blocks.countdown_timer.settings.animate_num.label",
        "options": [
          {
            "value": "none",
            "label": "t:blocks.countdown_timer.settings.animate_num.options__1.label"
          },
          {
            "value": "move_top",
            "label": "t:blocks.countdown_timer.settings.animate_num.options__2.label"
          },
          {
            "value": "move_bottom",
            "label": "t:blocks.countdown_timer.settings.animate_num.options__3.label"
          },
          {
            "value": "scale",
            "label": "t:blocks.countdown_timer.settings.animate_num.options__4.label"
          },
          {
            "value": "rotate",
            "label": "t:blocks.countdown_timer.settings.animate_num.options__5.label"
          }
        ],
        "default": "move_top"
      },
      {
        "type": "checkbox",
        "id": "prepend_number",
        "label": "t:blocks.countdown_timer.settings.prepend_number.label",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "hide_on_complete",
        "default": false,
        "label": "t:blocks.countdown_timer.settings.hide_on_complete.label"
      },
      {
        "type": "text",
        "id": "mess_complete",
        "label": "t:blocks.countdown_timer.settings.mess_complete.label"
      },
      {
        "type": "color",
        "id": "number_color",
        "label": "t:blocks.countdown_timer.settings.number_color.label",
        "default": "#fff",
        "alpha": true
      },
      {
        "type": "color",
        "id": "text_color",
        "label": "t:blocks.countdown_timer.settings.text_color.label",
        "default": "#fff",
        "alpha": true
      },
      {
        "type": "color",
        "id": "border_color",
        "label": "t:blocks.countdown_timer.settings.border_color.label",
        "default": "#000",
        "alpha": true
      },
      {
        "type": "color",
        "id": "background_color",
        "label": "t:blocks.countdown_timer.settings.background_color.label",
        "default": "#000",
        "alpha": true
      },
      {
        "type": "checkbox",
        "id": "hide_on_mobile",
        "label": "t:blocks.countdown_timer.settings.hide_on_mobile.label",
        "default": false
      },
      {
        "type": "number",
        "id": "margin_bottom",
        "label": "t:blocks.countdown_timer.settings.margin_bottom.label",
        "default":0
      },
      {
        "type": "number",
        "id": "margin_bottom_mobile",
        "label": "t:blocks.countdown_timer.settings.margin_bottom_mobile.label",
        "default":0
      }
    ],
    "presets":[
      {
        "name": "t:blocks.countdown_timer.name"
      }
    ]
  }
{% endschema %}
