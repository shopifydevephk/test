{%- liquid
  assign value_index = section.blocks | find_index: 'id', block.id 
  assign color_list = 'products.theme_settings.color' | t | downcase | strip | replace: ' ,', ',' | replace: ', ', ',' | split: ',' | uniq
  assign size_list = 'products.theme_settings.size' | t | downcase | strip | replace: ' ,', ',' | replace: ', ', ',' | split: ',' | uniq 
-%}
 {%- if block.settings.product != blank -%}
  {% assign product = block.settings.product %}
  <!--item-title>
  <button type="button" value="{{ value_index }}" aria-current="false" class="hdt-pin-size-medium hdt-pin_btn hdt-radius-full hdt-pin-type-1 hdt-absolute no-js-hidden" style="--pos-x: {{ block.settings.left }}%; --pos-y: {{ block.settings.top }}%;--pin-bg: {{ block.settings.pin_bg.rgb }}; --pin-text: {{ block.settings.pin_text.rgb }};" {{ block.shopify_attributes }}>
    <span class="hdt-zoompin"></span>
    <span class="hdt-pin-icon"></span>
    <span class="sr-only">{{ 'accessibility.go_to_item' | t: number: value_index }}</span><span></span>
  </button>
  -->
  {%- liquid
    case section.settings.product_des
      when '1'
        capture btn_wishlist_code
          if settings.wishlist_mode != '0'
            render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'right'
          endif
        endcapture
        render 'card-product1', card_product: product, class: "hdt-slider__slide hdt-pr-style1", section_id: section.id, sizes: sizes, image_ratio: section.settings.image_ratio, color_list: color_list, size_list: size_list, btn_wishlist_code: btn_wishlist_code, show_vendor: section.settings.show_vendor
      when '2'
        capture btn_wishlist_code
          if settings.wishlist_mode != '0'
            render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'top'
          endif
        endcapture
        render 'card-product2', card_product: product, section_id: section.id, class: "hdt-slider__slide hdt-pr-style2", sizes: sizes, image_ratio: section.settings.image_ratio, color_list: color_list, size_list: size_list, btn_wishlist_code: btn_wishlist_code, show_vendor: section.settings.show_vendor
      when '3'
        capture btn_wishlist_code
          if settings.wishlist_mode != '0'
            render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'left'
          endif
        endcapture
        render 'card-product3', card_product: product, section_id: section.id, class: "hdt-slider__slide hdt-pr-style3", sizes: sizes, image_ratio: section.settings.image_ratio, color_list: color_list, size_list: size_list, btn_wishlist_code: btn_wishlist_code, show_vendor: section.settings.show_vendor
      when '4'
        capture btn_wishlist_code
          if settings.wishlist_mode != '0'
            render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'top'
          endif
        endcapture
        render 'card-product4', card_product: product, section_id: section.id, class: "hdt-slider__slide hdt-pr-style4", sizes: sizes, image_ratio: section.settings.image_ratio, color_list: color_list, size_list: size_list, btn_wishlist_code: btn_wishlist_code, show_vendor: section.settings.show_vendor
      when '5'
        capture btn_wishlist_code
          if settings.wishlist_mode != '0'
            render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'left'
          endif
        endcapture
        render 'card-product5', card_product: product, section_id: section.id, class: "hdt-slider__slide hdt-pr-style5", sizes: sizes, image_ratio: section.settings.image_ratio, color_list: color_list, size_list: size_list, btn_wishlist_code: btn_wishlist_code, show_vendor: section.settings.show_vendor
      when '6'
        capture btn_wishlist_code
          if settings.wishlist_mode != '0'
            render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'left'
          endif
        endcapture
        render 'card-product6', card_product: product, section_id: section.id, class: "hdt-slider__slide hdt-pr-style6", sizes: sizes, image_ratio: section.settings.image_ratio, color_list: color_list, size_list: size_list, btn_wishlist_code: btn_wishlist_code, show_vendor: section.settings.show_vendor
      when '7'
        capture btn_wishlist_code
          if settings.wishlist_mode != '0'
            render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'left'
          endif
        endcapture
        render 'card-product7', card_product: product, section_id: section.id, class: "hdt-slider__slide hdt-pr-style7", sizes: sizes, image_ratio: section.settings.image_ratio, color_list: color_list, size_list: size_list, btn_wishlist_code: btn_wishlist_code
      when '8'
        capture btn_wishlist_code
          if settings.wishlist_mode != '0'
            render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'left'
          endif
        endcapture
        render 'card-product8', card_product: product, section_id: section.id, class: "hdt-slider__slide hdt-pr-style8", sizes: sizes, image_ratio: section.settings.image_ratio, color_list: color_list, size_list: size_list, btn_wishlist_code: btn_wishlist_code
      when '9'
        capture btn_wishlist_code
          if settings.wishlist_mode != '0'
            render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'right'
          endif
        endcapture
        render 'card-product9', card_product: product, section_id: section.id, class: "hdt-slider__slide hdt-pr-style9", sizes: sizes, image_ratio: section.settings.image_ratio, color_list: color_list, size_list: size_list, btn_wishlist_code: btn_wishlist_code
      when '10'
        capture btn_wishlist_code
          if settings.wishlist_mode != '0'
            render 'btn-wishlist', class: 'hdt-card-product__btn-wishlist hdt-pr_btn', placement: 'right'
          endif
        endcapture
        render 'card-product10', card_product: product, section_id: section.id, class: "hdt-slider__slide hdt-pr-style10", sizes: sizes, image_ratio: section.settings.image_ratio, color_list: color_list, size_list: size_list, btn_wishlist_code: btn_wishlist_code
    endcase 
  -%}
{% else %}
  <!--item-title>
  <button type="button" value="{{ value_index }}" aria-current="false" class="hdt-pin-size-medium hdt-pin_btn hdt-radius-full hdt-pin-type-1 hdt-absolute no-js-hidden" style="--pos-x: {{ block.settings.left }}%; --pos-y: {{ block.settings.top }}%;--pin-bg: {{ block.settings.pin_bg.rgb }}; --pin-text: {{ block.settings.pin_text.rgb }};" {{ block.shopify_attributes }}>
    <span class="hdt-zoompin"></span>
    <span class="hdt-pin-icon"></span>
    <span class="sr-only">{{ 'accessibility.go_to_item' | t: number: value_index }}</span><span></span>
  </button>
  -->
  {% liquid
    assign placeholder_image = 'product-apparel-1'
    render 'card-product-placeholder', image_ratio: block.settings.image_ratio, placeholder_image: placeholder_image, section_id: section.id, class: "hdt-slider__slide"
  %}
{%- endif -%} 
{% schema %}
  {
    "name": "t:blocks.pin.name",
    "tag": null,
    "settings": [
      {
        "type": "color",
        "id": "pin_bg",
        "label": "t:blocks.pin_product.settings.pin_bg.label",
        "default": "#FA3044E5",
        "alpha": true
      },
      {
        "type": "color",
        "id": "pin_text",
        "label": "t:blocks.pin_product.settings.pin_text.label",
        "default": "#fff",
        "alpha": true
      },
      {
        "type": "range",
        "id": "left",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "%",
        "label": "t:blocks.pin_product.settings.left.label",
        "default": 50
      },
      {
        "type": "range",
        "id": "top",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "%",
        "label": "t:blocks.pin_product.settings.top.label",
        "default": 50
      },
      {
        "type": "product",
        "id": "product",
        "label": "t:blocks.pin_product.settings.product.label"
      },
    ],
    "presets": [
      {
        "name": "t:blocks.pin.name"
      }
    ]
  }
{% endschema %}
